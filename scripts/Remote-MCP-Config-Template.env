# Remote GitHub MCP Server Configuration Template
# Copy these variables to your .env file when migrating to remote server

# =============================================================================
# REMOTE GITHUB MCP SERVER CONFIGURATION
# =============================================================================

# Server Connection
MCP_SERVER_URL=https://your-mcp-server.example.com/github
MCP_SERVER_PORT=3001
MCP_API_KEY=your_mcp_api_key_here

# WebSocket Configuration (for real-time features)
MCP_WEBSOCKET_URL=wss://your-mcp-server.example.com/github
MCP_RECONNECT_INTERVAL=5000
MCP_CONNECTION_TIMEOUT=30000

# Load Balancing (for high availability)
MCP_LOAD_BALANCER_URLS=https://mcp-server-1.example.com/github,https://mcp-server-2.example.com/github
MCP_LOAD_BALANCING_STRATEGY=round-robin

# Advanced GitHub Configuration
GITHUB_BASE_URL=https://github.example.com
GITHUB_API_VERSION=2022-11-28
GITHUB_REQUEST_TIMEOUT=30000
GITHUB_MAX_RETRIES=3
GITHUB_RETRY_DELAY=1000

# Authentication
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_PRIVATE_KEY_PATH=/path/to/private-key.pem

# Security
MCP_TLS_CERT_PATH=/path/to/server.crt
MCP_TLS_KEY_PATH=/path/to/server.key
MCP_ENABLE_AUTH=true

# Monitoring and Logging
MCP_LOG_LEVEL=info
MCP_METRICS_ENABLED=true
MCP_HEALTH_CHECK_INTERVAL=30000

# Rate Limiting
MCP_RATE_LIMIT_REQUESTS_PER_MINUTE=60
MCP_RATE_LIMIT_BURST_SIZE=10

# Caching
MCP_CACHE_ENABLED=true
MCP_CACHE_TTL=300000
MCP_CACHE_SIZE_MB=100
