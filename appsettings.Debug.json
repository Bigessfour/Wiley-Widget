{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Syncfusion": "Trace",
      "System.Windows": "Debug",
      "WileyWidget": "Debug"
    },
    "Console": {
      "IncludeScopes": true,
      "TimestampFormat": "yyyy-MM-dd HH:mm:ss.fff "
    },
    "File": {
      "Path": "logs/wiley-widget-debug-.txt",
      "Append": true,
      "FileSizeLimitBytes": 10485760,
      "MaxRollingFiles": 5,
      "IncludeScopes": true
    }
  },
  "SYNCFUSION_DEBUG": true,
  "WPF_THEME_DEBUG": true,
  "THEME_CRASH_DEBUGGING": true,
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=WileyWidget.db"
  }
}
