# BusBuddy Environment Variables
# Copy this to your BusBuddy/.env file and fill in the values

# Azure Configuration (BusBuddy-RG)
BUSBUDDY_AZURE_SUBSCRIPTION_ID=your_busbuddy_subscription_id
BUSBUDDY_AZURE_TENANT_ID=your_busbuddy_tenant_id
BUSBUDDY_AZURE_CLIENT_ID=your_busbuddy_client_id
BUSBUDDY_AZURE_CLIENT_SECRET=your_busbuddy_client_secret

# Azure SQL Database (BusBuddy)
BUSBUDDY_AZURE_SQL_SERVER=your_busbuddy_sql_server.database.windows.net
BUSBUDDY_AZURE_SQL_DATABASE=busbuddy-db
BUSBUDDY_AZURE_SQL_USER=busbuddyadmin
BUSBUDDY_AZURE_SQL_PASSWORD=your_busbuddy_sql_password

# GitHub Configuration (BusBuddy)
BUSBUDDY_GITHUB_TOKEN=your_busbuddy_github_token

# Application Specific
BUSBUDDY_ENVIRONMENT=Development
