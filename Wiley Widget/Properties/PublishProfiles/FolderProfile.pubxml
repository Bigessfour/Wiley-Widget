<?xml version="1.0" encoding="utf-8"?>
<!--
Enhanced publish profile with detailed diagnostics for troubleshooting missing dependencies.
Use: dotnet publish -p:PublishProfile=FolderProfile
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>publish\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net9.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    
    <!-- Enhanced Diagnostic Settings -->
    <PublishTrimmed>false</PublishTrimmed>
    <TrimMode>partial</TrimMode>
    <SuppressTrimAnalysisWarnings>false</SuppressTrimAnalysisWarnings>
    
    <!-- Detailed MSBuild Logging -->
    <MSBuildVerbosity>detailed</MSBuildVerbosity>
    <LogLevel>Information</LogLevel>
    
    <!-- Assembly and Dependency Analysis -->
    <ShowDependencies>true</ShowDependencies>
    <PublishReferencesDocumentationFiles>true</PublishReferencesDocumentationFiles>
    <CopyOutputSymbolsToPublishDirectory>true</CopyOutputSymbolsToPublishDirectory>
    
    <!-- Syncfusion-specific dependency preservation -->
    <PreserveCompilationContext>true</PreserveCompilationContext>
    <PreserveCompilationReferences>true</PreserveCompilationReferences>
    
    <!-- Enhanced file tracking -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    
    <!-- WPF-specific settings -->
    <IncludeNETCoreAppRuntime>true</IncludeNETCoreAppRuntime>
    <UseAppHost>true</UseAppHost>
    
    <!-- Diagnostic output settings -->
    <ErrorReport>detailed</ErrorReport>
    <WarningLevel>4</WarningLevel>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <!-- Enhanced diagnostic targets -->
  <Target Name="PrePublishDiagnostics" BeforeTargets="PublishBuild">
    <Message Text="=== PRE-PUBLISH DIAGNOSTICS ===" Importance="high" />
    <Message Text="Configuration: $(Configuration)" Importance="high" />
    <Message Text="Target Framework: $(TargetFramework)" Importance="high" />
    <Message Text="Runtime Identifier: $(RuntimeIdentifier)" Importance="high" />
    <Message Text="Self Contained: $(SelfContained)" Importance="high" />
    <Message Text="Publish Directory: $(PublishDir)" Importance="high" />
    <Message Text="Output Directory: $(OutputPath)" Importance="high" />
    <Message Text="=== END PRE-PUBLISH DIAGNOSTICS ===" Importance="high" />
  </Target>

  <Target Name="ListPublishedFiles" AfterTargets="Publish">
    <Message Text="=== PUBLISHED FILES ANALYSIS ===" Importance="high" />
    <ItemGroup>
      <PublishedFiles Include="$(PublishDir)**\*.*" />
    </ItemGroup>
    <Message Text="Total published files: @(PublishedFiles->Count())" Importance="high" />
    <Message Text="Published Syncfusion assemblies:" Importance="high" />
    <Message Text="  %(PublishedFiles.Filename)%(PublishedFiles.Extension)" 
             Condition="$([System.String]::Copy('%(PublishedFiles.Filename)').Contains('Syncfusion'))" 
             Importance="high" />
    <Message Text="=== END PUBLISHED FILES ANALYSIS ===" Importance="high" />
  </Target>

  <!-- Detailed dependency analysis -->
  <Target Name="AnalyzeDependencies" AfterTargets="ResolveReferences">
    <Message Text="=== DEPENDENCY ANALYSIS ===" Importance="high" />
    <Message Text="Reference assemblies count: @(ReferencePath->Count())" Importance="high" />
    <Message Text="Syncfusion references found:" Importance="high" />
    <Message Text="  %(ReferencePath.Filename)" 
             Condition="$([System.String]::Copy('%(ReferencePath.Filename)').Contains('Syncfusion'))" 
             Importance="high" />
    <Message Text="Native libraries:" Importance="high" />
    <Message Text="  %(NativeCopyLocalItems.Filename)%(NativeCopyLocalItems.Extension)" 
             Condition="'@(NativeCopyLocalItems)' != ''" 
             Importance="high" />
    <Message Text="=== END DEPENDENCY ANALYSIS ===" Importance="high" />
  </Target>

  <!-- Enhanced error reporting -->
  <Target Name="PublishErrorDiagnostics" AfterTargets="Publish" Condition="'$(MSBuildLastTaskResult)' == 'false'">
    <Message Text="=== PUBLISH ERROR DIAGNOSTICS ===" Importance="high" />
    <Message Text="Publish failed. Check the following:" Importance="high" />
    <Message Text="1. All Syncfusion packages are properly referenced" Importance="high" />
    <Message Text="2. Runtime dependencies are available" Importance="high" />
    <Message Text="3. Target framework is correctly specified" Importance="high" />
    <Message Text="4. Output directory permissions" Importance="high" />
    <Message Text="=== END PUBLISH ERROR DIAGNOSTICS ===" Importance="high" />
  </Target>
</Project>
