<Window x:Class="WileyWidget.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:converters="clr-namespace:WileyWidget.Converters"
        mc:Ignorable="d"
        Title="Wiley Widget" Height="450" Width="800">
    <Window.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <converters:BalanceToColorConverter x:Key="BalanceToColorConverter"/>
            <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
        </ResourceDictionary>
    </Window.Resources>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Home">
                <MenuItem Header="Copy" />
                <MenuItem Header="Paste" />
                <Separator />
                <MenuItem Header="Refresh" />
            </MenuItem>
            <MenuItem Header="Theme">
                <MenuItem Header="Fluent Dark" Click="OnFluentDark" />
                <MenuItem Header="Fluent Light" Click="OnFluentLight" />
            </MenuItem>
            <MenuItem Header="Data">
                <MenuItem Header="Next" Command="{Binding SelectNextCommand}" />
                <MenuItem Header="Add" Command="{Binding AddWidgetCommand}" />
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About" Click="OnAbout" />
            </MenuItem>
        </Menu>

        <DockPanel LastChildFill="True">
            <TabControl x:Name="MainTabControl">
                <TabItem Header="Widgets">
                    <DataGrid ItemsSource="{Binding Widgets}" SelectedItem="{Binding SelectedWidget, Mode=TwoWay}" 
                             AutoGenerateColumns="False" x:Name="Grid" IsReadOnly="True"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             EnableRowVirtualization="True"
                             EnableColumnVirtualization="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="70" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" />
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" />
                            <DataGridTextColumn Header="Price" Binding="{Binding Price}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Enterprises">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="4">
                            <Button Content="Load Enterprises" Command="{Binding LoadEnterprisesCommand}" Margin="0,0,6,0"/>
                            <Button Content="Add Enterprise" Command="{Binding AddEnterpriseCommand}" Margin="0,0,6,0"/>
                            <Button Content="Save" Command="{Binding SaveEnterpriseCommand}" Margin="0,0,6,0"/>
                            <Button Content="Delete" Command="{Binding DeleteEnterpriseCommand}" Margin="0,0,6,0"/>
                            <Button Content="Test Config" Command="{Binding TestConfigurationCommand}" Margin="0,0,6,0" 
                                    ToolTip="Test xAI API key configuration"/>
                            <Button Content="Crunch with Grok" Command="{Binding CrunchWithGrokCommand}" Margin="0,0,6,0" 
                                    FontWeight="Bold" ToolTip="Analyze enterprises with AI"/>
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding Enterprises}" SelectedItem="{Binding SelectedEnterprise, Mode=TwoWay}" 
                                 AutoGenerateColumns="False" IsReadOnly="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 EnableRowVirtualization="True"
                                 EnableColumnVirtualization="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200" />
                                <DataGridTextColumn Header="Rate" Binding="{Binding CurrentRate}" Width="100" />
                                <DataGridTextColumn Header="Rate Payers" Binding="{Binding CitizenCount}" Width="100" />
                                <DataGridTextColumn Header="Expenses" Binding="{Binding MonthlyExpenses}" Width="120" />
                                <DataGridTextColumn Header="Revenue" Binding="{Binding MonthlyRevenue}" Width="120" />
                                <DataGridTextColumn Header="Balance" Binding="{Binding MonthlyBalance}" Width="120" />
                                <DataGridTextColumn Header="Deficit" Binding="{Binding Deficit}" Width="100" />
                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="200" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Budget Summary">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <TextBlock Text="Municipal Budget Dashboard" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            
                            <UniformGrid Columns="2" Rows="2" Margin="0,0,0,20">
                                <Border Style="{StaticResource DashboardCard}">
                                    <StackPanel>
                                        <TextBlock Text="Total Revenue" Style="{StaticResource CardTitle}"/>
                                        <TextBlock Text="{Binding BudgetMetrics.TotalRevenue, StringFormat=C2}" Style="{StaticResource CardValue}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashboardCard}">
                                    <StackPanel>
                                        <TextBlock Text="Total Expenses" Style="{StaticResource CardTitle}"/>
                                        <TextBlock Text="{Binding BudgetMetrics.TotalExpenses, StringFormat=C2}" Style="{StaticResource CardValue}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashboardCard}">
                                    <StackPanel>
                                        <TextBlock Text="Monthly Balance" Style="{StaticResource CardTitle}"/>
                                        <TextBlock Text="{Binding BudgetMetrics.MonthlyBalance, StringFormat=C2}" Style="{StaticResource CardValue}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashboardCard}">
                                    <StackPanel>
                                        <TextBlock Text="Rate Payers Served" Style="{StaticResource CardTitle}"/>
                                        <TextBlock Text="{Binding BudgetMetrics.TotalCitizens}" Style="{StaticResource CardValue}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Style="{StaticResource DashboardCard}" CornerRadius="10" Margin="0,0,0,20" Padding="20">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding BudgetMetrics.StatusIcon}" FontSize="48" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding BudgetMetrics.StatusMessage}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                    <TextBlock Text="{Binding BudgetMetrics.StatusDescription}" FontSize="14" HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!--
                            <GroupBox Header="Revenue vs Expenses Overview" Margin="0,0,0,20">
                                <TextBlock Text="Chart visualization would go here" Height="300" Margin="10" 
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </GroupBox>
                            -->

                            <GroupBox Header="Enterprise Performance Details" Margin="0,0,0,20">
                                <DataGrid ItemsSource="{Binding Enterprises}" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Enterprise" Binding="{Binding Name}" Width="120"/>
                                        <DataGridTextColumn Header="Rate Payers" Binding="{Binding CitizenCount}" Width="80"/>
                                        <DataGridTextColumn Header="Rate ($)" Binding="{Binding CurrentRate}" Width="80"/>
                                        <DataGridTextColumn Header="Revenue ($)" Binding="{Binding MonthlyRevenue}" Width="100"/>
                                        <DataGridTextColumn Header="Expenses ($)" Binding="{Binding MonthlyExpenses}" Width="100"/>
                                        <DataGridTextColumn Header="Balance ($)" Binding="{Binding MonthlyBalance}" Width="100"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding BudgetStatus}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>

                            <GroupBox Header="Budget Insights &amp; Recommendations" Margin="0,0,0,20">
                                <StackPanel Margin="10">
                                    <TextBlock Text="{Binding BudgetInsights.MainInsight}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <TextBlock Text="Key Recommendations:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ItemsControl ItemsSource="{Binding BudgetInsights.Recommendations}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource DashboardCard}" CornerRadius="4" Margin="0,2" Padding="8">
                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Border Background="{StaticResource WarningBackground}" BorderBrush="{StaticResource WarningBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,10,0,0" Padding="8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding BudgetInsights.Disclaimer}" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource WarningTextForeground}"/>
                                            <Button Content="Export for CPA Review" HorizontalAlignment="Center" Margin="0,8,0,0" Padding="8,4" Command="{Binding ExportForCpaCommand}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </GroupBox>

                            <TextBlock Text="Dashboard provides real-time budget analytics with visual indicators and actionable insights."/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Budget Interactions">
                    <TextBlock Text="Budget Interactions feature - Coming Soon" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                </TabItem>
                <TabItem Header="QuickBooks">
                    <TextBlock Text="QuickBooks Integration - Coming Soon" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                </TabItem>
                <TabItem Header="Settings">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                                            <TextBlock Text="Timeout (seconds):" Margin="0,0,0,5"/>
                                            <TextBox x:Name="TimeoutTextBox" Text="30" Margin="0,0,0,2"
                                                     Style="{StaticResource ValidatedTextBox}"/>
                                            <TextBlock Text="{Binding ElementName=TimeoutTextBox, Path=(Validation.Errors)[0].ErrorContent}"
                                                       Style="{StaticResource ValidationErrorStyle}"
                                                       Visibility="{Binding ElementName=TimeoutTextBox, Path=(Validation.HasError), Converter={StaticResource BoolToVis}}"/>
                                            
                                            <TextBlock Text="Cache TTL (minutes):" Margin="0,8,0,5"/>
                                            <TextBox x:Name="CacheTtlTextBox" Text="30" Margin="0,0,0,2"
                                                     Style="{StaticResource ValidatedTextBox}"/>
                                            <TextBlock Text="{Binding ElementName=CacheTtlTextBox, Path=(Validation.Errors)[0].ErrorContent}"
                                                             Style="{StaticResource ValidationErrorStyle}"
                                                             Visibility="{Binding ElementName=CacheTtlTextBox, Path=(Validation.HasError), Converter={StaticResource BoolToVis}}"/>
                                            
                                            <TextBlock Text="Daily Budget ($):" Margin="0,8,0,5"/>
                                            <TextBox x:Name="DailyBudgetTextBox" Text="10.00" Margin="0,0,0,2"
                                                     Style="{StaticResource ValidatedTextBox}"/>
                                            <TextBlock Text="{Binding ElementName=DailyBudgetTextBox, Path=(Validation.Errors)[0].ErrorContent}"
                                                             Style="{StaticResource ValidationErrorStyle}"
                                                             Visibility="{Binding ElementName=DailyBudgetTextBox, Path=(Validation.HasError), Converter={StaticResource BoolToVis}}"/>
                                            
                                            <TextBlock Text="Monthly Budget ($):" Margin="0,8,0,5"/>
                                            <TextBox x:Name="MonthlyBudgetTextBox" Text="300.00" Margin="0,0,0,2"
                                                     Style="{StaticResource ValidatedTextBox}"/>
                                            <TextBlock Text="{Binding ElementName=MonthlyBudgetTextBox, Path=(Validation.Errors)[0].ErrorContent}"
                                                             Style="{StaticResource ValidationErrorStyle}"
                                                             Visibility="{Binding ElementName=MonthlyBudgetTextBox, Path=(Validation.HasError), Converter={StaticResource BoolToVis}}"/>
                                            
                                            <!-- API Key Configuration -->
                                            <GroupBox Header="xAI API Configuration" Margin="0,20,0,20">
                                                <StackPanel Margin="10">
                                                    <TextBlock Text="API Key:" Margin="0,0,0,5"/>
                                                    <TextBox x:Name="ApiKeyBox" Margin="0,0,0,2"
                                                             Style="{StaticResource ValidatedTextBox}"/>
                                                    <TextBlock Text="{Binding ElementName=ApiKeyBox, Path=(Validation.Errors)[0].ErrorContent}"
                                                               Style="{StaticResource ValidationErrorStyle}"
                                                               Visibility="{Binding ElementName=ApiKeyBox, Path=(Validation.HasError), Converter={StaticResource BoolToVis}}"/>
                                                    
                                                    <!-- Theme Selection -->
                                                    <TextBlock Text="Theme:" Margin="0,15,0,5"/>
                                                    <ComboBox x:Name="ThemeComboBox" Margin="0,0,0,2">
                                                        <ComboBoxItem Content="Fluent Dark"/>
                                                        <ComboBoxItem Content="Fluent Light"/>
                                                    </ComboBox>
                                                    
                                                    <!-- Model Selection -->
                                                    <TextBlock Text="xAI Model:" Margin="0,15,0,5"/>
                                                    <ComboBox x:Name="ModelComboBox" Margin="0,0,0,10">
                                                        <ComboBoxItem Content="grok-beta"/>
                                                        <ComboBoxItem Content="grok-vision-beta"/>
                                                    </ComboBox>
                                                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                                        <syncfusion:ButtonAdv Content="Test API Key" Click="OnTestApiKey" 
                                                                Background="{StaticResource TestApiBackground}" Foreground="{StaticResource TestConfigForeground}" 
                                                                Margin="0,0,10,0" Padding="20,10" Style="{StaticResource ThemeSfButton}"/>
                                                        <syncfusion:ButtonAdv Content="Save Settings" Click="OnSaveSettings" 
                                                                Background="{StaticResource SaveSettingsBackground}" Foreground="{StaticResource TestConfigForeground}" 
                                                                Margin="0,0,10,0" Padding="20,10" Style="{StaticResource ThemeSfButton}"/>
                                                        <syncfusion:ButtonAdv Content="Load Settings" Click="OnLoadSettings" 
                                                                Background="{StaticResource LoadSettingsBackground}" Foreground="{StaticResource TestConfigForeground}" 
                                                                Margin="0,0,10,0" Padding="20,10" Style="{StaticResource ThemeSfButton}"/>
                                                        <syncfusion:ButtonAdv Content="Remove API Key" Click="OnRemoveApiKey" 
                                                                Background="{StaticResource RemoveApiBackground}" Foreground="{StaticResource TestConfigForeground}" 
                                                                Margin="0,0,10,0" Padding="20,10" Style="{StaticResource ThemeSfButton}"/>
                                                        <syncfusion:ButtonAdv Content="API Key Info" Click="OnShowApiKeyInfo" 
                                                                Background="{StaticResource ApiInfoBackground}" Foreground="{StaticResource TestConfigForeground}" 
                                                                Padding="20,10" Style="{StaticResource ThemeSfButton}"/>
                                                    </StackPanel>
                                                    
                                                    <!-- Status Display -->
                                                    <Border x:Name="StatusBorder" BorderBrush="{StaticResource StatusBorderBrush}" BorderThickness="1" 
                                                           Margin="0,20,0,0" Padding="10" CornerRadius="5">
                                                        <TextBlock x:Name="ApiKeyStatusText" 
                                                                 Text="Ready to configure xAI API key. Click 'Load Settings' to see current configuration."
                                                                 TextWrapping="Wrap"/>
                                                    </Border>
                                                </StackPanel>
                                            </GroupBox>

                                            <!-- Quick Start Guide -->
                                            <GroupBox Header="Quick Start Guide" Margin="0,0,0,20">
                                                <StackPanel Margin="10">
                                                    <TextBlock Text="New to xAI API keys?" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                    <TextBlock Text="1. Visit https://x.ai and create an account" Margin="0,0,0,5"/>
                                                    <TextBlock Text="2. Go to API Keys section in your profile" Margin="0,0,0,5"/>
                                                    <TextBlock Text="3. Generate a new API key" Margin="0,0,0,5"/>
                                                    <TextBlock Text="4. Copy the key and paste it above" Margin="0,0,0,5"/>
                                                    <TextBlock Text="5. Click 'Test API Key' to verify" Margin="0,0,0,15"/>
                                                    <syncfusion:ButtonAdv Content="Open xAI API Key Guide" Click="OnOpenApiGuide" 
                                                           Background="{StaticResource GuideButtonBackground}" Foreground="{StaticResource GuideButtonForeground}" Padding="15,8" Style="{StaticResource ThemeSfButton}"/>
                                                </StackPanel>
                                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
            <Border DockPanel.Dock="Bottom" Style="{StaticResource ThemeStatusBarBorder}" Padding="5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="10,0">
                        <Run Text="Items: "/><Run Text="{Binding Widgets.Count, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Margin="10,0">
                        <Run Text="Selected: "/><Run Text="{Binding SelectedWidget.Name}" />
                    </TextBlock>
                    <TextBlock Margin="10,0">
                        <Run Text="Price: "/><Run Text="{Binding SelectedWidget.Price}" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </DockPanel>
    </DockPanel>
</Window>
