<Window x:Class="WileyWidget.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
    xmlns:converters="clr-namespace:WileyWidget.Converters"
    mc:Ignorable="d"
    Title="Wiley Widget" Height="450" Width="800"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="Auto"
    DataContextChanged="MainWindow_DataContextChanged">
    <Window.Resources>
        <!-- Local resources intentionally minimal; BoolToVis moved to global dictionary -->
    </Window.Resources>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Home">
                <MenuItem Header="Copy" />
                <MenuItem Header="Paste" />
                <Separator />
                <MenuItem Header="Refresh" />
            </MenuItem>
            <!-- Dynamic theme menu bound to ThemeCoordinator -->
            <MenuItem x:Name="ThemeMenu" Header="Theme" 
                      ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ThemeCoordinator.Themes}">
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding}" />
                        <EventSetter Event="Click" Handler="OnThemeMenuItemClick" />
                    </Style>
                </MenuItem.ItemContainerStyle>
            </MenuItem>
            <MenuItem Header="Data">
                <MenuItem Header="Next" Command="{Binding SelectNextCommand}" />
                <MenuItem Header="Add" Command="{Binding AddWidgetCommand}" />
            </MenuItem>
            <MenuItem Header="Debug">
                <MenuItem Header="Watch Mode" Command="{Binding ToggleWatchModeCommand}" 
                         IsCheckable="True" IsChecked="{Binding WatchMode, Mode=TwoWay}" />
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About" Click="OnAbout" />
            </MenuItem>
        </Menu>

        <DockPanel LastChildFill="True">
            <TabControl x:Name="MainTabControl">
                <TabItem Header="Widgets">
                    <!-- Added deferred scrolling & pixel snapping per Microsoft WPF performance guidelines -->
                    <syncfusion:SfDataGrid ItemsSource="{Binding Widgets}" SelectedItem="{Binding SelectedWidget, Mode=TwoWay}" 
                                         AutoGenerateColumns="False" x:Name="Grid"
                                         AllowEditing="False" AllowGrouping="True" AllowSorting="True"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                                         ScrollViewer.IsDeferredScrollingEnabled="True"
                                         SnapsToDevicePixels="True">
                        <syncfusion:SfDataGrid.Columns>
                            <syncfusion:GridTextColumn HeaderText="Id" MappingName="Id" Width="70" />
                            <syncfusion:GridTextColumn HeaderText="Name" MappingName="Name" />
                            <syncfusion:GridTextColumn HeaderText="Category" MappingName="Category" />
                            <syncfusion:GridTextColumn HeaderText="Price" MappingName="Price" />
                        </syncfusion:SfDataGrid.Columns>
                    </syncfusion:SfDataGrid>
                </TabItem>
                <TabItem Header="Enterprises">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="4">
                            <Button Content="Load Enterprises" Command="{Binding LoadEnterprisesCommand}" Margin="0,0,6,0"/>
                            <Button Content="Add Enterprise" Command="{Binding AddEnterpriseCommand}" Margin="0,0,6,0"/>
                            <Button Content="Save" Command="{Binding SaveEnterpriseCommand}" Margin="0,0,6,0"/>
                            <Button Content="Delete" Command="{Binding DeleteEnterpriseCommand}" Margin="0,0,6,0"/>
                            <Button Content="Test Config" Command="{Binding TestConfigurationCommand}" Margin="0,0,6,0" 
                                    ToolTip="Test xAI API key configuration"/>
                            <Button Content="Crunch with Grok" Command="{Binding CrunchWithGrokCommand}" Margin="0,0,6,0" 
                                    FontWeight="Bold" ToolTip="Analyze enterprises with AI"/>
                        </StackPanel>
                        <!-- Named EnterprisesGrid to align with code-behind expectations & enable diagnostics -->
                        <syncfusion:SfDataGrid x:Name="EnterprisesGrid" ItemsSource="{Binding Enterprises}" SelectedItem="{Binding SelectedEnterprise, Mode=TwoWay}" 
                                             AutoGenerateColumns="False"
                                             AllowEditing="False" AllowGrouping="True" AllowSorting="True"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling"
                                             VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                                             ScrollViewer.IsDeferredScrollingEnabled="True"
                                             SnapsToDevicePixels="True">
                            <syncfusion:SfDataGrid.Columns>
                                <syncfusion:GridTextColumn HeaderText="Name" MappingName="Name" Width="200" />
                                <syncfusion:GridTextColumn HeaderText="Rate" MappingName="CurrentRate" Width="100" />
                                <syncfusion:GridTextColumn HeaderText="Rate Payers" MappingName="CitizenCount" Width="100" />
                                <syncfusion:GridTextColumn HeaderText="Expenses" MappingName="MonthlyExpenses" Width="120" />
                                <syncfusion:GridTextColumn HeaderText="Revenue" MappingName="MonthlyRevenue" Width="120" />
                                <syncfusion:GridTextColumn HeaderText="Balance" MappingName="MonthlyBalance" Width="120" />
                                <syncfusion:GridTextColumn HeaderText="Deficit" MappingName="Deficit" Width="100" />
                                <syncfusion:GridTextColumn HeaderText="Notes" MappingName="Notes" Width="200" />
                            </syncfusion:SfDataGrid.Columns>
                        </syncfusion:SfDataGrid>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Budget Summary">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <TextBlock Text="Municipal Budget Dashboard" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            
                            <UniformGrid Columns="2" Rows="2" Margin="0,0,0,20">
                                <Border Style="{DynamicResource DashboardCard}">
                                    <StackPanel>
                                        <TextBlock Text="Total Revenue" Style="{DynamicResource CardTitle}"/>
                                        <TextBlock Text="{Binding BudgetMetrics.TotalRevenue, StringFormat=C2}" Style="{DynamicResource CardValue}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{DynamicResource DashboardCard}">
                                    <StackPanel>
                                        <TextBlock Text="Total Expenses" Style="{DynamicResource CardTitle}"/>
                                        <TextBlock Text="{Binding BudgetMetrics.TotalExpenses, StringFormat=C2}" Style="{DynamicResource CardValue}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{DynamicResource DashboardCard}">
                                    <StackPanel>
                                        <TextBlock Text="Monthly Balance" Style="{DynamicResource CardTitle}"/>
                                        <TextBlock Text="{Binding BudgetMetrics.MonthlyBalance, StringFormat=C2}" Style="{DynamicResource CardValue}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{DynamicResource DashboardCard}">
                                    <StackPanel>
                                        <TextBlock Text="Rate Payers Served" Style="{DynamicResource CardTitle}"/>
                                        <TextBlock Text="{Binding BudgetMetrics.TotalCitizens}" Style="{DynamicResource CardValue}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Style="{DynamicResource DashboardCard}" CornerRadius="10" Margin="0,0,0,20" Padding="20">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding BudgetMetrics.StatusIcon}" FontSize="48" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding BudgetMetrics.StatusMessage}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                    <TextBlock Text="{Binding BudgetMetrics.StatusDescription}" FontSize="14" HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!--
                            <GroupBox Header="Revenue vs Expenses Overview" Margin="0,0,0,20">
                                <TextBlock Text="Chart visualization would go here" Height="300" Margin="10" 
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </GroupBox>
                            -->

                            <GroupBox Header="Enterprise Performance Details" Margin="0,0,0,20">
                                <DataGrid ItemsSource="{Binding Enterprises}" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Enterprise" Binding="{Binding Name}" Width="120"/>
                                        <DataGridTextColumn Header="Rate Payers" Binding="{Binding CitizenCount}" Width="80"/>
                                        <DataGridTextColumn Header="Rate ($)" Binding="{Binding CurrentRate}" Width="80"/>
                                        <DataGridTextColumn Header="Revenue ($)" Binding="{Binding MonthlyRevenue}" Width="100"/>
                                        <DataGridTextColumn Header="Expenses ($)" Binding="{Binding MonthlyExpenses}" Width="100"/>
                                        <DataGridTextColumn Header="Balance ($)" Binding="{Binding MonthlyBalance}" Width="100"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding BudgetStatus}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>

                            <GroupBox Header="Budget Insights &amp; Recommendations" Margin="0,0,0,20">
                                <StackPanel Margin="10">
                                    <TextBlock Text="{Binding BudgetInsights.MainInsight}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <TextBlock Text="Key Recommendations:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ItemsControl ItemsSource="{Binding BudgetInsights.Recommendations}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{DynamicResource DashboardCard}" CornerRadius="4" Margin="0,2" Padding="8">
                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Border Background="{DynamicResource WarningBackground}" BorderBrush="{DynamicResource WarningBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,10,0,0" Padding="8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding BudgetInsights.Disclaimer}" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource WarningTextForeground}"/>
                                            <Button Content="Export for CPA Review" HorizontalAlignment="Center" Margin="0,8,0,0" Padding="8,4" Command="{Binding ExportForCpaCommand}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </GroupBox>

                            <TextBlock Text="Dashboard provides real-time budget analytics with visual indicators and actionable insights."/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Budget Interactions">
                    <TextBlock Text="Budget Interactions feature - Coming Soon" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                </TabItem>
                <TabItem Header="QuickBooks">
                    <TextBlock Text="QuickBooks Integration - Coming Soon" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                </TabItem>
                <TabItem Header="Settings">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10" DataContext="{Binding Settings}">
                                            <TextBlock Text="Timeout (seconds):" Margin="0,0,0,5"/>
                                            <TextBox x:Name="TimeoutTextBox" Text="{Binding TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,2"
                                                     Style="{DynamicResource ValidatedTextBox}"/>
                                            <TextBlock Text="{Binding ElementName=TimeoutTextBox, Path=(Validation.Errors)[0].ErrorContent}"
                                                       Style="{DynamicResource ValidationErrorStyle}"
                                                       Visibility="{Binding ElementName=TimeoutTextBox, Path=(Validation.HasError), Converter={StaticResource BoolToVis}}"/>
                                            
                                            <TextBlock Text="Cache TTL (minutes):" Margin="0,8,0,5"/>
                                            <TextBox x:Name="CacheTtlTextBox" Text="{Binding CacheTtlMinutes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,2"
                                                     Style="{DynamicResource ValidatedTextBox}"/>
                                            <TextBlock Text="{Binding ElementName=CacheTtlTextBox, Path=(Validation.Errors)[0].ErrorContent}"
                                                             Style="{DynamicResource ValidationErrorStyle}"
                                                             Visibility="{Binding ElementName=CacheTtlTextBox, Path=(Validation.HasError), Converter={StaticResource BoolToVis}}"/>
                                            
                                            <TextBlock Text="Daily Budget ($):" Margin="0,8,0,5"/>
                                            <TextBox x:Name="DailyBudgetTextBox" Text="{Binding DailyBudget, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,2"
                                                     Style="{DynamicResource ValidatedTextBox}"/>
                                            <TextBlock Text="{Binding ElementName=DailyBudgetTextBox, Path=(Validation.Errors)[0].ErrorContent}"
                                                             Style="{DynamicResource ValidationErrorStyle}"
                                                             Visibility="{Binding ElementName=DailyBudgetTextBox, Path=(Validation.HasError), Converter={StaticResource BoolToVis}}"/>
                                            
                                            <TextBlock Text="Monthly Budget ($):" Margin="0,8,0,5"/>
                                            <TextBox x:Name="MonthlyBudgetTextBox" Text="{Binding MonthlyBudget, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,2"
                                                     Style="{DynamicResource ValidatedTextBox}"/>
                                            <TextBlock Text="{Binding ElementName=MonthlyBudgetTextBox, Path=(Validation.Errors)[0].ErrorContent}"
                                                             Style="{DynamicResource ValidationErrorStyle}"
                                                             Visibility="{Binding ElementName=MonthlyBudgetTextBox, Path=(Validation.HasError), Converter={StaticResource BoolToVis}}"/>
                                            
                                            <!-- API Key Configuration -->
                                            <GroupBox Header="xAI API Configuration" Margin="0,20,0,20">
                                                <StackPanel Margin="10">
                                                    <TextBlock Text="API Key:" Margin="0,0,0,5"/>
                                                    <TextBox x:Name="ApiKeyBox" Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,2"
                                                             Style="{DynamicResource ValidatedTextBox}"/>
                                                    <TextBlock Text="{Binding ElementName=ApiKeyBox, Path=(Validation.Errors)[0].ErrorContent}"
                                                               Style="{DynamicResource ValidationErrorStyle}"
                                                               Visibility="{Binding ElementName=ApiKeyBox, Path=(Validation.HasError), Converter={StaticResource BoolToVis}}"/>
                                                    
                                                    <!-- Theme Selection -->
                                                    <TextBlock Text="Theme:" Margin="0,15,0,5"/>
                                                    <ComboBox x:Name="ThemeComboBox" ItemsSource="{Binding Source={RelativeSource AncestorType=Window}, Path=ThemeCoordinator.Themes}" 
                                                             SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" Margin="0,0,0,2"/>
                                                    
                                                    <!-- Model Selection -->
                                                    <TextBlock Text="xAI Model:" Margin="0,15,0,5"/>
                                                    <ComboBox x:Name="ModelComboBox" SelectedItem="{Binding SelectedModel, Mode=TwoWay}" Margin="0,0,0,10">
                                                        <ComboBoxItem Content="grok-beta" />
                                                        <ComboBoxItem Content="grok-vision-beta" />
                                                    </ComboBox>
                                                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <syncfusion:ButtonAdv Content="Test API Key" Command="{Binding TestApiKeyAsyncCommand}" 
                                Background="{DynamicResource TestApiBackground}" Foreground="{DynamicResource TestConfigForeground}" 
                                Margin="0,0,10,0" Padding="20,10" Style="{DynamicResource ThemeSfButton}"/>
                            <syncfusion:ButtonAdv Content="Save Settings" Command="{Binding SaveCommand}" 
                                Background="{DynamicResource SaveSettingsBackground}" Foreground="{DynamicResource TestConfigForeground}" 
                                Margin="0,0,10,0" Padding="20,10" Style="{DynamicResource ThemeSfButton}"/>
                            <syncfusion:ButtonAdv Content="Load Settings" Command="{Binding LoadCommand}" 
                                Background="{DynamicResource LoadSettingsBackground}" Foreground="{DynamicResource TestConfigForeground}" 
                                Margin="0,0,10,0" Padding="20,10" Style="{DynamicResource ThemeSfButton}"/>
                            <syncfusion:ButtonAdv Content="Remove API Key" Command="{Binding RemoveApiKeyCommand}" 
                                Background="{DynamicResource RemoveApiBackground}" Foreground="{DynamicResource TestConfigForeground}" 
                                Margin="0,0,10,0" Padding="20,10" Style="{DynamicResource ThemeSfButton}"/>
                            <syncfusion:ButtonAdv Content="API Key Info" Command="{Binding ShowApiInfoCommand}" 
                                Background="{DynamicResource ApiInfoBackground}" Foreground="{DynamicResource TestConfigForeground}" 
                                Padding="20,10" Style="{DynamicResource ThemeSfButton}"/>
                                                    </StackPanel>
                                                    
                                                    <!-- Status Display -->
                                                    <Border x:Name="StatusBorder" BorderBrush="{StaticResource StatusBorderBrush}" BorderThickness="1" 
                                                           Margin="0,20,0,0" Padding="10" CornerRadius="5">
                                                        <TextBlock x:Name="ApiKeyStatusText" Text="{Binding StatusMessage}"
                                                                 TextWrapping="Wrap"/>
                                                    </Border>
                                                </StackPanel>
                                            </GroupBox>

                                            <!-- Quick Start Guide -->
                                            <GroupBox Header="Quick Start Guide" Margin="0,0,0,20">
                                                <StackPanel Margin="10">
                                                    <TextBlock Text="New to xAI API keys?" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                    <TextBlock Text="1. Visit https://x.ai and create an account" Margin="0,0,0,5"/>
                                                    <TextBlock Text="2. Go to API Keys section in your profile" Margin="0,0,0,5"/>
                                                    <TextBlock Text="3. Generate a new API key" Margin="0,0,0,5"/>
                                                    <TextBlock Text="4. Copy the key and paste it above" Margin="0,0,0,5"/>
                                                    <TextBlock Text="5. Click 'Test API Key' to verify" Margin="0,0,0,15"/>
                               <syncfusion:ButtonAdv Content="Open xAI API Key Guide" Command="{Binding OpenGuideCommand}" 
                                   Background="{DynamicResource GuideButtonBackground}" Foreground="{DynamicResource GuideButtonForeground}" Padding="15,8" Style="{DynamicResource ThemeSfButton}"/>
                                                </StackPanel>
                                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
            <Border DockPanel.Dock="Bottom" Style="{DynamicResource ThemeStatusBarBorder}" Padding="5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="10,0">
                        <Run Text="Items: "/><Run Text="{Binding Widgets.Count, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Margin="10,0">
                        <Run Text="Selected: "/><Run Text="{Binding SelectedWidget.Name}" />
                    </TextBlock>
                    <TextBlock Margin="10,0">
                        <Run Text="Price: "/><Run Text="{Binding SelectedWidget.Price}" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </DockPanel>
    </DockPanel>
</Window>
