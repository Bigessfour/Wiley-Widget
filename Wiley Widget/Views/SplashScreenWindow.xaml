<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WileyWidget"
        mc:Ignorable="d"
        x:Class="WileyWidget.SplashScreenWindow"
        Title="Wiley Widget"
        Height="400"
        Width="600"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#2D3748"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False">

    <Window.Resources>
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.5"/>
        </Storyboard>

        <Storyboard x:Key="ProgressStoryboard">
            <DoubleAnimation Storyboard.TargetName="ProgressBar"
                           Storyboard.TargetProperty="Value"
                           From="0" To="100" Duration="0:0:2"/>
        </Storyboard>
    </Window.Resources>

    <Border CornerRadius="12" BorderBrush="#4A5568" BorderThickness="2">
        <Grid>
            <!-- Background Gradient -->
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1A202C" Offset="0"/>
                    <GradientStop Color="#2D3748" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Main Content -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">

                <!-- Logo/Icon Area -->
                <Border Width="120" Height="120" CornerRadius="60"
                        Background="#4299E1" Margin="0,0,0,30"
                        HorizontalAlignment="Center">
                    <TextBlock Text="⚙️"
                             FontSize="48"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Foreground="White"/>
                </Border>

                <!-- Application Title -->
                <TextBlock Text="WILEY WIDGET"
                         FontSize="32"
                         FontWeight="Bold"
                         Foreground="#E2E8F0"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,10"
                         FontFamily="Segoe UI"/>

                <!-- Subtitle -->
                <TextBlock Text="Enterprise Management System"
                         FontSize="16"
                         Foreground="#A0AEC0"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,40"
                         FontFamily="Segoe UI"/>

                <!-- Progress Section -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock x:Name="StatusText"
                             Text="Initializing application..."
                             FontSize="14"
                             Foreground="#CBD5E0"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,15"
                             FontFamily="Segoe UI"/>

                    <!-- Progress Bar -->
                    <Border CornerRadius="4" Background="#4A5568" Margin="40,0">
                        <ProgressBar x:Name="ProgressBar"
                                   Height="6"
                                   Value="0"
                                   Foreground="#4299E1"
                                   Background="Transparent"
                                   BorderThickness="0"/>
                    </Border>

                    <!-- Progress Text -->
                    <TextBlock x:Name="ProgressText"
                             Text="0%"
                             FontSize="12"
                             Foreground="#A0AEC0"
                             HorizontalAlignment="Center"
                             Margin="0,10,0,0"
                             FontFamily="Segoe UI"/>
                </StackPanel>

                <!-- Version Info -->
                <TextBlock x:Name="VersionText"
                         Text="Version 1.0.0"
                         FontSize="12"
                         Foreground="#718096"
                         HorizontalAlignment="Center"
                         FontFamily="Segoe UI"/>
            </StackPanel>

            <!-- Loading Animation Dots -->
            <StackPanel Orientation="Horizontal"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,30">
                <Ellipse x:Name="Dot1" Width="8" Height="8" Fill="#4299E1" Margin="0,0,8,0" Opacity="1"/>
                <Ellipse x:Name="Dot2" Width="8" Height="8" Fill="#4299E1" Margin="0,0,8,0" Opacity="0.5"/>
                <Ellipse x:Name="Dot3" Width="8" Height="8" Fill="#4299E1" Margin="0,0,8,0" Opacity="0.3"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
