<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Spacing & layout metrics -->
  <Thickness x:Key="Space.XS">2</Thickness>
  <Thickness x:Key="Space.SM">4</Thickness>
  <Thickness x:Key="Space.MD">8</Thickness>
  <Thickness x:Key="Space.LG">12</Thickness>
  <Thickness x:Key="Space.XL">20</Thickness>

  <!-- Window metrics -->
  <Thickness x:Key="WindowOuterPadding">12</Thickness>
</ResourceDictionary>