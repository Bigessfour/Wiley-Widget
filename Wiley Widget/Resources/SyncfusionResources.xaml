<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:WileyWidget"
                    xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                    xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF">

    <!-- Syncfusion themes are loaded automatically by SfSkinManager -->
    <!-- This file contains only custom application styles that complement the active theme -->

    <!-- Global converters moved to App.xaml fallback dictionary (BoolToVis) -->

    <!-- Custom application styles that complement Fluent theme -->
    <Style x:Key="ThemeButton" TargetType="Button">
        <Setter Property="Background" Value="#0078D4"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#0078D4"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#106EBE"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#005A9E"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#CCCCCC"/>
                            <Setter Property="Foreground" Value="#666666"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- StatusTextSuccess TextBlock Style -->
    <Style x:Key="StatusTextSuccess" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#107C10"/>
        <Setter Property="FontStyle" Value="Italic"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <!-- StatusTextInfo (Similar) -->
    <Style x:Key="StatusTextInfo" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#0078D4"/>
        <Setter Property="FontStyle" Value="Italic"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,5,0,0"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <!-- BusyText -->
    <Style x:Key="BusyText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#FF6B35"/>
        <Setter Property="FontStyle" Value="Italic"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <!-- StatusBar Style (Expanded with ItemsPanel) -->
    <Style x:Key="ThemeStatusBar" TargetType="StatusBar">
        <Setter Property="Background" Value="#F3F3F3"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <DockPanel LastChildFill="True"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- StatusBarItem Style -->
    <Style x:Key="ThemeStatusBarItem" TargetType="StatusBarItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <!-- Primitive brushes & common colors removed (now sourced from Colors.xaml / palette). Only keep unique module-specific brushes below if any truly differ. -->


    <!-- Status Bar Border Style -->
    <Style x:Key="ThemeStatusBarBorder" TargetType="Border">
        <Setter Property="Background" Value="#F3F3F3"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Height" Value="25"/>
    </Style>

    <!-- Duplicate validation styles removed; authoritative definitions reside in Controls.Base.xaml -->

    <!-- Ribbon Styles (Uncommented and properly defined per Syncfusion documentation) -->
    <Style x:Key="ThemeRibbon" TargetType="syncfusion:Ribbon">
        <Setter Property="Background" Value="#F3F3F3"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="ThemeRibbonTab" TargetType="syncfusion:RibbonTab">
        <Setter Property="Background" Value="#F3F3F3"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="ThemeRibbonBar" TargetType="syncfusion:RibbonBar">
        <Setter Property="Background" Value="#F3F3F3"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="ThemeRibbonButton" TargetType="syncfusion:RibbonButton">
        <Setter Property="Background" Value="#0078D4"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#0078D4"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>

    <!-- Tab Control Styles -->
    <Style x:Key="ThemeTabControl" TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- SfDataGrid Style - Testing basic properties -->
    <Style x:Key="ThemeSfDataGrid" TargetType="syncfusion:SfDataGrid">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <!-- Advanced row properties not available as direct properties on SfDataGrid -->
        <!-- RowBackground and AlternatingRowBackground properties not supported -->
        <!-- These would need to be implemented via RowStyle or custom templates -->
    </Style>

    <!-- SfChart Style - Testing basic properties -->
    <Style x:Key="ThemeSfChart" TargetType="syncfusion:SfChart">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <!-- Virtualization property may not be available -->
        <!-- <Setter Property="Virtualization" Value="True"/> -->
    </Style>

    <!-- SfButton Style -->
    <Style x:Key="ThemeSfButton" TargetType="syncfusion:ButtonAdv">
        <Setter Property="Background" Value="#0078D4"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#0078D4"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="syncfusion:ButtonAdv">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#106EBE"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#005A9E"/>
                            <Setter Property="BorderBrush" Value="#005A9E"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#CCCCCC"/>
                            <Setter Property="Foreground" Value="#666666"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- SfDiagram Style -->
    <Style x:Key="ThemeSfDiagram" TargetType="syncfusion:SfDiagram">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <!-- Virtualization property not available on SfDiagram -->
        <!-- <Setter Property="Virtualization" Value="True"/> -->
    </Style>

    <!-- SfComboBox Style -->
    <Style x:Key="ThemeSfComboBox" TargetType="syncfusion:ComboBoxAdv">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>

    <!-- SfAccordion Styles - Package now installed -->
    <Style x:Key="ThemeSfAccordion" TargetType="syncfusion:SfAccordion">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

