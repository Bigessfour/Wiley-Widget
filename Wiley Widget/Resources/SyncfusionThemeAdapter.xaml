<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Keys that Syncfusion internal templates often look for; map to our unified palette -->
  <SolidColorBrush x:Key="SyncfusionAccentBrush" Color="{DynamicResource AccentColorKey}" />
  <SolidColorBrush x:Key="SyncfusionPrimaryBrush" Color="{DynamicResource AccentColorKey}" />
  <SolidColorBrush x:Key="SyncfusionDisabledBrush" Color="{DynamicResource DisabledBackground}" />
  <SolidColorBrush x:Key="SyncfusionBorderBrush" Color="{DynamicResource Color.Base.Border.Light}" />
</ResourceDictionary>