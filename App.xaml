<Application xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WileyWidget.App">
    <!-- Simplified: core dictionaries loaded programmatically in LoadCoreResources() -->
    <Application.Resources>
        <ResourceDictionary>
            <!-- Minimal always-available fallbacks -->
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <!-- Proactive fallback brushes/styles for referenced UI elements -->
            <SolidColorBrush x:Key="StatusBorderBrush" Color="#FFB0B0B0" />
            <SolidColorBrush x:Key="StatusBackground" Color="#FFF8F8F8" />
            <SolidColorBrush x:Key="WarningBackground" Color="#FFFFF4E5" />
            <SolidColorBrush x:Key="WarningBorderBrush" Color="#FFE0B060" />
            <SolidColorBrush x:Key="WarningTextForeground" Color="#FF4A3A00" />
            <SolidColorBrush x:Key="TestApiBackground" Color="#FF2D7DD2" />
            <SolidColorBrush x:Key="SaveSettingsBackground" Color="#FF2E8B57" />
            <SolidColorBrush x:Key="LoadSettingsBackground" Color="#FF4169E1" />
            <SolidColorBrush x:Key="RemoveApiBackground" Color="#FFB22222" />
            <SolidColorBrush x:Key="ApiInfoBackground" Color="#FF8A2BE2" />
            <SolidColorBrush x:Key="GuideButtonBackground" Color="#FF1976D2" />
            <SolidColorBrush x:Key="GuideButtonForeground" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="TestConfigForeground" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="ThemeStatusBarBackground" Color="#FF202124" />
            <SolidColorBrush x:Key="ThemeStatusBarBorderBrush" Color="#33000000" />
            <Style x:Key="ThemeStatusBarBorder" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource ThemeStatusBarBackground}" />
                <Setter Property="BorderBrush" Value="{StaticResource ThemeStatusBarBorderBrush}" />
                <Setter Property="BorderThickness" Value="1,0,0,0" />
            </Style>
            <Style x:Key="ThemeSfButton" TargetType="Button" BasedOn="{x:Null}">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Cursor" Value="Hand" />
            </Style>
            <!-- Validation style fallbacks (authoritative versions in Controls.Base.xaml) -->
            <Style x:Key="ValidationErrorStyle" TargetType="TextBlock" x:Shared="False">
                <Setter Property="Foreground" Value="Red" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Margin" Value="0,0,0,2" />
            </Style>
            <Style x:Key="ValidatedTextBox" TargetType="TextBox" x:Shared="False">
                <Setter Property="Validation.ErrorTemplate">
                    <Setter.Value>
                        <ControlTemplate>
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="!" Foreground="Red" FontWeight="Bold" Margin="0,0,4,0"/>
                                <AdornedElementPlaceholder/>
                            </DockPanel>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="Text.Body" TargetType="TextBlock" x:Shared="False" BasedOn="{x:Null}">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="Foreground" Value="Black" />
            </Style>
            <!-- Fallback dashboard text styles (authoritative versions in Controls.Base.xaml) -->
            <Style x:Key="CardTitle" TargetType="TextBlock" BasedOn="{StaticResource Text.Body}" x:Shared="False">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style x:Key="CardValue" TargetType="TextBlock" BasedOn="{StaticResource Text.Body}" x:Shared="False">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="DarkBlue" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
