<Application xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WileyWidget.App"
             xmlns:local="clr-namespace:WileyWidget"
             StartupUri="Wiley%20Widget/Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Syncfusion theme resources for WPF 30.2.7 -->
                <ResourceDictionary Source="/Syncfusion.Themes.FluentLight.WPF;component/FluentLight.xaml"/>
                <ResourceDictionary Source="/Syncfusion.Themes.FluentDark.WPF;component/FluentDark.xaml"/>
                
                <!-- Custom application resources - Standard location -->
                <ResourceDictionary Source="Resources/SyncfusionResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
