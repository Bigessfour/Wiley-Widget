<Application xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WileyWidget">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Syncfusion themes are loaded automatically by SfSkinManager -->
                <!-- Custom application resources only (no theme resources) -->
                <ResourceDictionary Source="pack://application:,,,/WileyWidget;component/Wiley Widget/Resources/SyncfusionResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
