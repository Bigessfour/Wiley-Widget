<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <config>
        <!-- Speed up NuGet operations -->
        <add
            key="globalPackagesFolder"
            value="%USERPROFILE%\.nuget\packages" />
        <add
            key="repositoryPath"
            value="packages" />
        <add
            key="http_proxy"
            value="" />
        <add
            key="http_proxy.user"
            value="" />
        <add
            key="signatureValidationMode"
            value="accept" />
        <add
            key="maxHttpRequestsPerSource"
            value="16" />
        <add
            key="allowInsecureConnections"
            value="true" />
    </config>
    <packageSources>
        <clear />
        <!-- Private NuGet feed for Syncfusion patches (priority) - commented out for build -->
        <!-- <add
            key="WileyPrivate"
            value="http://localhost:5000/v3/index.json" /> -->
        <!-- Official NuGet.org feed -->
        <add
            key="nuget.org"
            value="https://api.nuget.org/v3/index.json"
            protocolVersion="3" />
    </packageSources>
    <packageSourceMapping>
        <!-- Syncfusion packages from private feed first (for patches) - commented out -->
        <!-- <packageSource key="WileyPrivate">
            <package pattern="Syncfusion.*" />
        </packageSource> -->
        <!-- All other packages from nuget.org -->
        <packageSource key="nuget.org">
            <package pattern="*" />
        </packageSource>
    </packageSourceMapping>
    <!-- API key for private feed push operations (set via environment variable) -->
    <apikeys>
        <!--
        To add API key for push operations:
        dotnet nuget setapikey YOUR_API_KEY -Source http://localhost:5000/v3/index.json
        -->
    </apikeys>
</configuration>
