{
  "exclude_patterns": [
    "archive/",
    "ci-logs/",
    "%USERPROFILE%/",
    "docs/",
    "scripts/",
    "tools/",
    "test/",
    "tests/",
    "TestResults/",
    "WileyWidget.IntegrationTests/",
    "WileyWidget.Services.UnitTests/",
    "licenses/",
    "signing/",
    "wwwroot/",
    "schemas/",
    "config/",
    "Properties/",
    "Styles/",
    "Services/",
    "ViewModels/",
    "filter_manifest\\.py$",
    "test_csx_files\\.py$",
    "test-vscode-config\\.ps1$",
    "CHANGELOG\\.md$",
    "CONTRIBUTING\\.md$",
    "SECURITY\\.md$",
    "SETUP_GUIDE\\.md$"
  ],
  "focus_mode": true,
  "include_only_extensions": [
    ".cs",
    ".csproj",
    ".sln",
    ".xaml",
    ".config",
    ".json",
    ".props",
    ".targets",
    ".md"
  ],
  "include_critical_files": [
    "WileyWidget.WinForms/WileyWidget.WinForms.csproj",
    "src/WileyWidget.Models/Models/MunicipalAccount.cs",
    "src/WileyWidget.Data/AppDbContext.cs",
    "WileyWidget.WinForms/ViewModels/AccountsViewModel.cs",
    ".vscode/launch.json",
    ".vscode/tasks.json",
    "WileyWidget.sln",
    "README.md",
    "Directory.Build.props",
    "Directory.Build.targets",
    "Directory.Packages.props",
    "global.json",
    "NuGet.config",
    "WileyWidget.Services.UnitTests/ChartFormTests.cs",
    "WileyWidget.Services.UnitTests/ChartServiceTests.cs",
    "WileyWidget.Services.UnitTests/ChartViewModelTests.cs",
    "WileyWidget.Services.UnitTests/PrintingServiceTests.cs",
    "tests/WileyWidget.Services.Tests/ServiceTests/EncryptedLocalSecretVaultServiceTests.cs",
    "tests/WileyWidget.Services.Tests/ServiceTests/QuickBooksServiceTests.cs",
    "tests/WileyWidget.WinForms.Tests/AccountsViewModelTests.cs",
    "tests/WileyWidget.WinForms.Tests/BudgetOverviewViewModelTests.cs"
  ],
  "max_files": 500,
  "emit_full_tree": false,
  "tree_max_depth": 4,
  "max_tree_entries_per_dir": 50,
  "test_file_summary_length": 50000,
  "max_summary_length": 2000
}
