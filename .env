# Wiley Widget Environment Configuration
# PowerShell 7.5.2 Compatible
# Follows Microsoft PowerShell Best Practices and Approved Verbs
# Generated using Microsoft Docs MCP recommendations

# =============================================================================
# PROJECT CONFIGURATION
# =============================================================================

# Project root directory and configuration
WILEY_WIDGET_ROOT=C:\Users\biges\Desktop\Wiley_Widget
WILEY_WIDGET_CONFIG=Release
WILEY_WIDGET_VERSION=1.0.0
WILEY_WIDGET_FRAMEWORK=net8.0-windows

# Build output directories
WILEY_WIDGET_BIN_DIR=%WILEY_WIDGET_ROOT%\WileyWidget\bin\%WILEY_WIDGET_CONFIG%\%WILEY_WIDGET_FRAMEWORK%
WILEY_WIDGET_OBJ_DIR=%WILEY_WIDGET_ROOT%\WileyWidget\obj\%WILEY_WIDGET_CONFIG%\%WILEY_WIDGET_FRAMEWORK%

# =============================================================================
# POWERSHELL 7.5.2 CONFIGURATION
# =============================================================================

# PowerShell execution policy (RemoteSigned recommended for development)
POWERSHELL_EXECUTION_POLICY=RemoteSigned

# PowerShell module paths (following PSModulePath best practices)
POWERSHELL_MODULE_PATH=%USERPROFILE%\Documents\PowerShell\Modules;%ProgramFiles%\PowerShell\Modules;%ProgramFiles%\PowerShell\7\Modules

# PowerShell profile configuration
POWERSHELL_PROFILE_CURRENT_USER_CURRENT_HOST=%USERPROFILE%\Documents\PowerShell\Microsoft.PowerShell_profile.ps1
POWERSHELL_PROFILE_CURRENT_USER_ALL_HOSTS=%USERPROFILE%\Documents\PowerShell\profile.ps1
POWERSHELL_PROFILE_ALL_USERS_CURRENT_HOST=%ProgramFiles%\PowerShell\7\Microsoft.PowerShell_profile.ps1
POWERSHELL_PROFILE_ALL_USERS_ALL_HOSTS=%ProgramFiles%\PowerShell\7\profile.ps1

# PowerShell telemetry (set to true to opt-out)
POWERSHELL_TELEMETRY_OPTOUT=false

# =============================================================================
# .NET DEVELOPMENT ENVIRONMENT
# =============================================================================

# .NET SDK and runtime configuration
DOTNET_ROOT=%ProgramFiles%\dotnet
DOTNET_CLI_TELEMETRY_OPTOUT=false
DOTNET_NOLOGO=true
DOTNET_ROLL_FORWARD=Major
DOTNET_CLI_HOME=%USERPROFILE%\.dotnet

# NuGet configuration
NUGET_PACKAGES=%USERPROFILE%\.nuget\packages
NUGET_HTTP_CACHE_PATH=%USERPROFILE%\.nuget\v3-cache
NUGET_PLUGINS_CACHE_PATH=%USERPROFILE%\.nuget\plugins-cache

# MSBuild configuration
MSBUILDDEBUGPATH=%TEMP%\MSBuildDebug
MSBuildSDKsPath=%ProgramFiles%\dotnet\sdk\%DOTNET_VERSION%\Sdks

# =============================================================================
# BUILD AND TESTING CONFIGURATION
# =============================================================================

# Build settings
BUILD_CONFIGURATION=%WILEY_WIDGET_CONFIG%
BUILD_PLATFORM=AnyCPU
BUILD_VERBOSITY=normal
BUILD_MAX_CPU_COUNT=0

# Test configuration
RUN_UI_TESTS=0
TEST_RESULTS_DIR=%WILEY_WIDGET_ROOT%\TestResults
TEST_PARALLEL_WORKERS=0
TEST_COLLECT_COVERAGE=true
TEST_COVERAGE_FORMAT=cobertura
TEST_COVERAGE_THRESHOLD=70

# Code analysis
CODE_ANALYSIS_RULE_SET=MinimumRecommendedRules
CODE_ANALYSIS_TREAT_WARNINGS_AS_ERRORS=false

# =============================================================================
# DEVELOPMENT TOOLS AND PATHS
# =============================================================================

# Extended PATH for development tools
PATH=%PATH%;%WILEY_WIDGET_ROOT%\scripts;%DOTNET_ROOT%;%ProgramFiles%\PowerShell\7

# Git configuration
GIT_CONFIG_GLOBAL=%USERPROFILE%\.gitconfig
GIT_CONFIG_SYSTEM=%ProgramFiles%\Git\etc\gitconfig

# Visual Studio Code settings
VSCODE_SETTINGS_DIR=%APPDATA%\Code\User
VSCODE_EXTENSIONS_DIR=%USERPROFILE%\.vscode\extensions

# =============================================================================
# SYNCFUSION CONFIGURATION
# =============================================================================

# Syncfusion license (set this to your actual license key)
# SYNCFUSION_LICENSE_KEY=your_license_key_here

# Syncfusion package versions
SYNCFUSION_PACKAGE_VERSION=30.2.4
SYNCFUSION_FRAMEWORK_VERSION=net8.0-windows

# =============================================================================
# API KEYS AND SECURE TOKENS
# =============================================================================
# Microsoft PowerShell 7.5.2 Security Best Practices for API Key Management
# - Never hardcode keys in scripts
# - Use environment variables for sensitive data
# - Implement proper access controls
# - Regularly rotate keys
# - Use secure string handling when possible

# GitHub API Configuration
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_1234567890abcdef1234567890abcdef1234567890abcdef
GITHUB_API_URL=https://api.github.com
GITHUB_REPOSITORY=Bigessfour/Wiley-Widget

# WebSocket MCP Server Configuration
MCP_SERVER_URL=wss://your-mcp-server.example.com/github
MCP_WEBSOCKET_URL=wss://your-mcp-server.example.com/github
MCP_RECONNECT_INTERVAL=5000
MCP_CONNECTION_TIMEOUT=30000
MCP_API_KEY=your_mcp_api_key_here

# Advanced GitHub Configuration for WebSocket
GITHUB_BASE_URL=https://github.com
GITHUB_API_VERSION=2022-11-28
GITHUB_REQUEST_TIMEOUT=30000
GITHUB_MAX_RETRIES=3
GITHUB_RETRY_DELAY=1000

# Trunk API Configuration
TRUNK_API_KEY=0fd8d7878ff0c1141fe2debbd354dd7ba0f04e99
TRUNK_TOKEN=%TRUNK_API_KEY%
TRUNK_ORGANIZATION=busbuddy
TRUNK_REPOSITORY=BusBuddy-3

# Trunk Integration Settings
TRUNK_CI=true
TRUNK_ENABLE_ACTIONS=true
TRUNK_ENABLE_FORMAT=true
TRUNK_ENABLE_LINTING=true
TRUNK_AUTO_FORMAT=true
TRUNK_AUTO_FORMAT_ON_PASTE=true
TRUNK_FORMAT_ON_SAVE=true
TRUNK_GIT_INTEGRATION=true
TRUNK_INLINE_DECORATORS=true
TRUNK_INLINE_DECORATORS_FOR_ALL_EXTENSIONS=true
TRUNK_SHOW_STATUS_IN_EXPLORER=true

# Azure OpenAI / ZAO Configuration
XAI_API_KEY=xai-waXPwUxdXJy4o5IcNEUpjyMaRtaJTqbH63RcG7Vi8aBig8UZUhz8R1ffdMTqj…
PSAOAI_API_AZURE_OPENAI_APIVERSION=2025-04-01-preview

# Brave Browser API
BRAVE_API_KEY=BSAKWu26BLu4KPdKvzX_QjMqL87KtHr

# Syncfusion License Key (from environment)
SYNCFUSION_LICENSE_KEY=YOUR_ACTUAL_SYNCFUSION_LICENSE_KEY_HERE

# API Key Security Settings
API_KEY_ENCRYPTION_ENABLED=false
API_KEY_VALIDATION_ENABLED=true
API_KEY_ROTATION_REMINDER_DAYS=30
API_KEY_LOG_ACCESS=false

# Secure Token Storage
SECURE_TOKEN_STORAGE_ENABLED=true
TOKEN_ENCRYPTION_ALGORITHM=AES256
TOKEN_BACKUP_ENABLED=false

# =============================================================================
# LOGGING AND DIAGNOSTICS
# =============================================================================

# Application logging
WILEY_WIDGET_LOG_DIR=%APPDATA%\WileyWidget\logs
WILEY_WIDGET_LOG_LEVEL=Information
WILEY_WIDGET_LOG_MAX_FILE_SIZE=10MB
WILEY_WIDGET_LOG_MAX_FILES=5

# Build diagnostics
BUILD_LOG_DIR=%WILEY_WIDGET_ROOT%\TestResults
BUILD_LOG_VERBOSITY=detailed
BUILD_LOG_INCLUDE_WARNINGS=true

# =============================================================================
# SECURITY AND COMPLIANCE
# =============================================================================

# Security settings
ENABLE_CODE_SIGNING=false
CERTIFICATE_THUMBPRINT=
TIMESTAMP_SERVER=http://timestamp.digicert.com

# Compliance settings
COMPLIANCE_CHECK_ENABLED=true
LICENSE_CHECK_ENABLED=true
DEPENDENCY_SCAN_ENABLED=true

# =============================================================================
# PERFORMANCE AND OPTIMIZATION
# =============================================================================

# Performance settings
ENABLE_PARALLEL_BUILD=true
ENABLE_INCREMENTAL_BUILD=true
ENABLE_FAST_UP_TO_DATE_CHECK=true

# Memory and resource settings
DOTNET_GC_CONCURRENT=true
DOTNET_GC_SERVER=true
DOTNET_GC_HEAP_COUNT=0

# =============================================================================
# INTEGRATION AND DEPLOYMENT
# =============================================================================

# GitHub integration
GITHUB_REPOSITORY=Bigessfour/Wiley-Widget
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com

# Azure/Cloud deployment (if applicable)
# AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# Container/Docker settings (if applicable)
# DOCKER_BUILDKIT=1
# DOCKER_HOST=
# DOCKER_TLS_VERIFY=

# =============================================================================
# USER-SPECIFIC CONFIGURATION
# =============================================================================

# User preferences
PREFERRED_EDITOR=code
PREFERRED_TERMINAL=wt
PREFERRED_BROWSER=msedge

# Development environment preferences
ENABLE_DARK_MODE=true
ENABLE_AUTO_SAVE=true
ENABLE_INTELLISENSE=true

# =============================================================================
# ADVANCED/CUSTOM CONFIGURATION
# =============================================================================

