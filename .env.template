# Wiley Widget Environment Configuration Template
# ==============================================
# Copy this file to .env and customize the values
# This file is used by terminal integration and MCP servers

# === AZURE CONFIGURATION ===
# Azure subscription and resource configuration
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_TENANT_ID=your-tenant-id-here
AZURE_RESOURCE_GROUP=wiley-widget-rg
AZURE_LOCATION=eastus

# === API KEYS (Load from Azure Key Vault) ===
# These are loaded automatically from Azure Key Vault
# Do not set these manually - they are managed by load-mcp-secrets.ps1
# SYNCFUSION_LICENSE_KEY=loaded-from-keyvault
# XAI_API_KEY=loaded-from-keyvault
# GITHUB_TOKEN=loaded-from-keyvault

# === TERMINAL INTEGRATION ===
# PowerShell 7.5.2 Configuration
POWERSHELL_EXECUTION_POLICY=Bypass
POWERSHELL_MODULE_PATH=%USERPROFILE%\Documents\PowerShell\Modules
POWERSHELL_PROFILE_PATH=%USERPROFILE%\Documents\PowerShell\Microsoft.PowerShell_profile.ps1

# Python Environment Configuration  
PYTHON_ENV_TYPE=venv
PYTHON_ENV_PATH=.venv
PYTHON_ENV_ACTIVATION_SCRIPT=.venv\Scripts\Activate.ps1
PYTHONPATH=.;src;scripts

# Node.js Environment Configuration
NODE_ENV=development
NPM_CONFIG_PREFIX=%APPDATA%\npm
NODE_PATH=%APPDATA%\npm\node_modules

# === MCP SERVER CONFIGURATION ===
# MCP Server Auto-startup Configuration
MCP_AUTO_START=true
MCP_SERVER_TIMEOUT=30
MCP_HEALTH_CHECK_INTERVAL=60

# GitHub MCP Server Configuration  
GITHUB_MCP_ENABLED=true
GITHUB_MCP_LOG_LEVEL=info

# Microsoft Docs MCP Server Configuration
MICROSOFT_DOCS_MCP_ENABLED=true
MICROSOFT_DOCS_MCP_LOG_LEVEL=info

# Pylance MCP Server Configuration
PYLANCE_MCP_ENABLED=true
PYLANCE_MCP_LOG_LEVEL=info

# === VS CODE TERMINAL PERSISTENCE ===
# Terminal state persistence configuration
TERMINAL_SAVE_STATE=true
TERMINAL_RESTORE_ON_STARTUP=true
TERMINAL_MAX_HISTORY_SIZE=10000
TERMINAL_WORKING_DIRECTORY_PERSISTENCE=true

# === DEVELOPMENT ENVIRONMENT ===
# Project-specific configuration
PROJECT_NAME=WileyWidget
PROJECT_ROOT=C:\Users\biges\Desktop\Wiley_Widget
BUILD_CONFIGURATION=Debug
LOG_LEVEL=Information

# === PERFORMANCE TUNING ===
# Terminal and MCP performance settings
TERMINAL_GPU_ACCELERATION=auto
TERMINAL_RENDERER=auto
MCP_BATCH_SIZE=10
MCP_CONNECTION_POOL_SIZE=5

# === SECURITY SETTINGS ===
# Security and compliance configuration
ENABLE_DETAILED_LOGGING=false
MASK_SENSITIVE_DATA=true
AUDIT_TERMINAL_COMMANDS=false

# === BACKUP AND RECOVERY ===
# Backup and disaster recovery settings
AUTO_BACKUP_ENVIRONMENT=true
BACKUP_RETENTION_DAYS=30
ENVIRONMENT_SNAPSHOT_INTERVAL=daily
