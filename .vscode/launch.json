    {
      "name": "Launch WileyWidget (WPF Debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/bin/Debug/net9.0-windows/WileyWidget.dll",
      "args": [],
