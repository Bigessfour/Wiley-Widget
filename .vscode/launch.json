{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch WileyWidget (Local)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/bin/Debug/net9.0-windows/WileyWidget.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "stopAtEntry": false,
      "logging": {
        "moduleLoad": false,
        "programOutput": true,
        "diagnosticsLog": {
          "protocolMessages": false
        }
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "LOG_LEVEL": "Debug"
      },
      "symbolOptions": {
        "searchPaths": [],
        "searchMicrosoftSymbolServer": false,
        "searchNuGetOrgSymbolServer": false,
        "cachePath": "${workspaceFolder}/.vscode/symbols",
        "moduleFilter": {
          "mode": "loadAllButExcluded",
          "excludedModules": [],
          "includedModules": ["WileyWidget.dll"],
          "includeSymbolsNextToModules": true,
          "includeSymbolsOnDemand": true
        }
      },
      "justMyCode": false,
      "requireExactSource": false,
      "enableStepFiltering": true,
      "suppressJITOptimizations": true,
      "internalConsoleOptions": "neverOpen",
      "presentation": {
        "hidden": false,
        "group": "",
        "order": 1
      }
    },
