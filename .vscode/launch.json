{
  "version": "0.2.0",
  "configurations": [

    {
      "name": "WinForms: Debug with Hot Reload",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/src/WileyWidget.WinForms/bin/Debug/net9.0-windows10.0.26100.0/WileyWidget.WinForms.exe",
      "args": [],
      "cwd": "${workspaceFolder}/src/WileyWidget.WinForms",
      "stopAtEntry": false,
      "console": "internalConsole",
      "preLaunchTask": "Debug: Hot Reload Setup",
      "justMyCode": false,
      "enableStepFiltering": false,
      "requireExactSource": false,
      "suppressJITOptimizations": true,
      "env": {
        "DOTNET_ENVIRONMENT": "Development",
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_WATCH_RESTART_ON_RUDE_EDIT": "true",
        "XAI_API_KEY": "${env:XAI_API_KEY}",
        "SYNCFUSION_LICENSE_KEY": "${env:SYNCFUSION_LICENSE_KEY}",
        "WW_DEBUG_EXCEPTIONS": "1"
      },
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "WinForms: Debug with Performance Monitoring",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/src/WileyWidget.WinForms/bin/Debug/net9.0-windows10.0.26100.0/WileyWidget.WinForms.exe",
      "args": [],
      "cwd": "${workspaceFolder}/src/WileyWidget.WinForms",
      "stopAtEntry": false,
      "console": "internalConsole",
      "preLaunchTask": "dotnet: build",
      "postDebugTask": "Debug: Performance Trace (30s)",
      "justMyCode": false,
      "enableStepFiltering": false,
      "requireExactSource": false,
      "suppressJITOptimizations": true,
      "logging": {
        "moduleLoad": true,
        "exceptions": true,
        "programOutput": true,
        "diagnosticsLog": {
          "protocolMessages": false,
          "startDebugging": true,
          "engineLogging": true
        },
        "threadExit": true,
        "processExit": true,
        "elapsedTiming": true,
        "trace": true,
        "traceResponse": true
      },
      "env": {
        "DOTNET_ENVIRONMENT": "Development",
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_EnableDiagnostics": "1",
        "DOTNET_EnableDiagnostics_Profiler": "1",
        "XAI_API_KEY": "${env:XAI_API_KEY}",
        "SYNCFUSION_LICENSE_KEY": "${env:SYNCFUSION_LICENSE_KEY}",
        "WW_DEBUG_EXCEPTIONS": "1"
      },
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Attach to Process",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    },
    {
      "name": "Debug C# Tests",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build",
      "program": "${workspaceFolder}/WileyWidget.Tests/bin/Debug/net9.0/WileyWidget.Tests.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "stopAtEntry": false
    },
    {
      "name": "Debug C# UI Tests",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build",
      "program": "${workspaceFolder}/WileyWidget.UiTests/bin/Debug/net9.0/WileyWidget.UiTests.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "stopAtEntry": false
    },
    {
      "name": "Run WileyWidget.Tests (dotnet test)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build",
      "program": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/WileyWidget.Tests/WileyWidget.Tests.csproj",
        "--no-restore",
        "--verbosity",
        "minimal"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false
    },

    {
      "name": "Run E2E Test (PanelViewModelResolutionTests) - Wait for Debugger",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build",
      "program": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/WileyWidget.E2ETests/WileyWidget.E2ETests.csproj",
        "--no-build",
        "--filter",
        "FullyQualifiedName~WileyWidget.IntegrationTests.PanelViewModelResolutionTests",
        "--verbosity",
        "minimal"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "env": {
        "VSTEST_HOST_DEBUG": "1"
      },
      "justMyCode": false
    },
    {
      "name": "Attach to testhost (pick process)",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}",
      "justMyCode": false
    },
    {
      "name": "Attach to SUT (pick process)",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}",
      "justMyCode": false
    }
  ],
  "compounds": [
    {
      "name": "Debug E2E: Run & Attach",
      "configurations": [
        "Run E2E Test (PanelViewModelResolutionTests) - Wait for Debugger",
        "Attach to testhost (pick process)"
      ]
    }
  ]
}
