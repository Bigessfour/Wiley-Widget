{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/WileyWidget.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "options": {
        "env": {
          "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
          "DOTNET_SKIP_FIRST_TIME_EXPERIENCE": "1"
        }
      }
    },
    {
      "label": "build-enhanced",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/build-enhanced.ps1",
        "-ProjectPath",
        "${workspaceFolder}/WileyWidget.csproj"
      ],
      "problemMatcher": "$msCompile",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "options": {
        "env": {
          "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
          "DOTNET_SKIP_FIRST_TIME_EXPERIENCE": "1"
        }
      }
    },
    {
      "label": "publish",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/WileyWidget.csproj",
        "-c",
        "Release",
        "-o",
        "${workspaceFolder}/publish"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "watch",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "run",
        "--project",
        "${workspaceFolder}/WileyWidget.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true,
      "group": "build"
    },
    {
      "label": "azure-setup",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/azure-setup.ps1"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "azure-test-connection",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/azure-setup.ps1",
        "-TestConnection"
      ],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "ef-migrations",
      "command": "dotnet",
      "type": "process",
      "args": ["ef", "migrations", "add", "${input:migrationName}"],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "ef-update",
      "command": "dotnet",
      "type": "process",
      "args": ["ef", "database", "update"],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "run-debug",
      "command": "dotnet",
      "type": "process",
      "args": ["run", "--project", "${workspaceFolder}/WileyWidget.csproj"],
      "options": {
        "env": {
          "ASPNETCORE_ENVIRONMENT": "Development",
          "LOG_LEVEL": "Debug",
          "SERILOG__MINIMUMLEVEL": "Debug"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "python: bootstrap env",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/bootstrap_python_env.ps1"
      ],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "python: install deps",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "if (Test-Path .venv) { . .\\.venv\\Scripts\\Activate.ps1 }; python -m pip install -r scripts/requirements.txt"
      ],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "debug-conhost",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/WileyWidget.csproj",
        "--debug-conhost"
      ],
      "options": {
        "env": {
          "ASPNETCORE_ENVIRONMENT": "Development",
          "LOG_LEVEL": "Debug",
          "SERILOG__MINIMUMLEVEL": "Debug"
        }
      },
      "problemMatcher": "$msCompile",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ],
  "inputs": [
    {
      "id": "migrationName",
      "description": "Name of the migration",
      "default": "NewMigration",
      "type": "promptString"
    }
  ]
}
