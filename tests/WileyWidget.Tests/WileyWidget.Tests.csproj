<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Uses net9.0-windows to match source projects -->
    <!-- For Docker: Use Windows containers or run tests natively with Docker DB -->
    <TargetFramework>net9.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <NoWarn>NU1902;NU1903;CA2000;CA1062;CA1307</NoWarn>

  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="Archived\**" />
    <Using Include="Xunit" />
  </ItemGroup>

  <ItemGroup>
    <!-- Test framework packages (versions managed in Directory.Packages.props) -->
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.runner.visualstudio">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="coverlet.collector">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>

    <!-- Mocking and assertions -->
    <PackageReference Include="Moq" />
    <PackageReference Include="FluentAssertions" />

    <!-- DI and configuration for integration tests -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Configuration" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />

    <!-- EF Core In-Memory for database testing -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" />

    <!-- Serilog for test logging -->
    <PackageReference Include="Serilog" />
    <PackageReference Include="Serilog.Extensions.Logging" />
    <PackageReference Include="Serilog.Sinks.Console" />

    <!-- Suppress Azure DocumentDB warnings -->
    <PackageReference Include="Serilog.Sinks.AzureDocumentDB" ExcludeAssets="All" />
    <PackageReference Include="Microsoft.Azure.DocumentDB.Core" ExcludeAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <!-- Core project references (no Windows dependencies) -->
    <ProjectReference Include="..\..\src\WileyWidget.Models\WileyWidget.Models.csproj" />
    <ProjectReference Include="..\..\src\WileyWidget.Data\WileyWidget.Data.csproj" />
    <ProjectReference Include="..\..\src\WileyWidget.Business\WileyWidget.Business.csproj" />
    <ProjectReference Include="..\..\src\WileyWidget.Services\WileyWidget.Services.csproj" />
    <ProjectReference Include="..\..\src\WileyWidget.Abstractions\WileyWidget.Abstractions.csproj" />
    <ProjectReference Include="..\..\src\WileyWidget.Services.Abstractions\WileyWidget.Services.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="appsettings.test.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>