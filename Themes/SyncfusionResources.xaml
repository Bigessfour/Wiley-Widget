    <!-- Validation Error Styles -->
    <Style x:Key="ValidationErrorStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{syncfusionskin:ThemeResource ThemeKey={syncfusionskin:ThemeKey Key=ErrorBrush}}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="ValidationErrorBorderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{syncfusionskin:ThemeResource ThemeKey={syncfusionskin:ThemeKey Key=ErrorBrush}}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Background" Value="{syncfusionskin:ThemeResource ThemeKey={syncfusionskin:ThemeKey Key=ErrorBackground}}"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
    </Style>

    <!-- Status Bar Border Style -->
    <Style x:Key="ThemeStatusBarBorder" TargetType="Border">
        <Setter Property="Background" Value="{syncfusionskin:ThemeResource ThemeKey={syncfusionskin:ThemeKey Key=StatusBarBackground}}"/>
        <Setter Property="BorderBrush" Value="{syncfusionskin:ThemeResource ThemeKey={syncfusionskin:ThemeKey Key=StatusBarBorderBrush}}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Height" Value="25"/>
    </Style>

    <!-- Enhanced TextBox Style with Validation -->
    <Style x:Key="ValidatedTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{syncfusionskin:ThemeResource ThemeKey={syncfusionskin:ThemeKey Key=ErrorBrush}}"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Background" Value="{syncfusionskin:ThemeResource ThemeKey={syncfusionskin:ThemeKey Key=ErrorBackground}}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

