    <!-- StatusTextSuccess TextBlock Style -->
    <Style x:Key="StatusTextSuccess" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{syncfusionskin:ThemeResource ThemeKey={syncfusionskin:ThemeKey Key=SuccessBrush}}"/>
        <Setter Property="FontStyle" Value="Italic"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="FontFamily" Value="{syncfusionskin:ThemeResource ThemeKey={syncfusionskin:ThemeKey Key=ContentFontFamily}}"/>
    </Style>

    <!-- StatusTextInfo (Similar) -->
    <Style x:Key="StatusTextInfo" TargetType="TextBlock">
