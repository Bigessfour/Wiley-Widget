    <!-- StatusBar Style (Expanded with ItemsPanel) -->
    <Style x:Key="ThemeStatusBar" TargetType="StatusBar">
        <Setter Property="Background" Value="{syncfusionskin:ThemeResource ThemeKey={syncfusionskin:ThemeKey Key=StatusBarBackground}}"/>
        <Setter Property="Foreground" Value="{syncfusionskin:ThemeResource ThemeKey={syncfusionskin:ThemeKey Key=StatusBarForeground}}"/>
        <Setter Property="BorderBrush" Value="{syncfusionskin:ThemeResource ThemeKey={syncfusionskin:ThemeKey Key=StatusBarBorderBrush}}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <DockPanel LastChildFill="True"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- StatusBarItem Style -->
    <Style x:Key="ThemeStatusBarItem" TargetType="StatusBarItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{syncfusionskin:ThemeResource ThemeKey={syncfusionskin:ThemeKey Key=StatusBarItemForeground}}"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="FontFamily" Value="{syncfusionskin:ThemeResource ThemeKey={syncfusionskin:ThemeKey Key=ContentFontFamily}}"/>
    </Style>

