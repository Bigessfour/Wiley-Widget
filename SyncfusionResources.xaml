    <SolidColorBrush x:Key="RemoveApiBackground" Color="#D13438"/>
    <SolidColorBrush x:Key="ApiInfoBackground" Color="#0078D4"/>
    <SolidColorBrush x:Key="StatusBorderBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="GuideButtonBackground" Color="#0078D4"/>
    <SolidColorBrush x:Key="GuideButtonForeground" Color="White"/>
    <SolidColorBrush x:Key="DiagramBackground" Color="White"/>
    <SolidColorBrush x:Key="RevenueChartColor" Color="#107C10"/>
    <SolidColorBrush x:Key="ExpensesChartColor" Color="#D13438"/>

    <!-- Validation Error Styles -->
    <Style x:Key="ValidationErrorStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#D13438"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="ValidationErrorBorderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="#D13438"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Background" Value="#FFF5F5"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
    </Style>

    <!-- Status Bar Border Style -->
    <Style x:Key="ThemeStatusBarBorder" TargetType="Border">
        <Setter Property="Background" Value="#F3F3F3"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Height" Value="25"/>
    </Style>

    <!-- Enhanced TextBox Style with Validation -->
    <Style x:Key="ValidatedTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="#D13438"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Background" Value="#FFF5F5"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Ribbon Styles (Uncommented and properly defined per Syncfusion documentation) -->
    <Style x:Key="ThemeRibbon" TargetType="syncfusion:Ribbon">
        <Setter Property="Background" Value="#F3F3F3"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="ThemeRibbonTab" TargetType="syncfusion:RibbonTab">
