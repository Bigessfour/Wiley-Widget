<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:WileyWidget"
                    xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                    xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF">

    <!-- Fluent Theme Resources (Loaded dynamically by SfSkinManager) -->
    <ResourceDictionary.MergedDictionaries>
        <!-- Theme resources will be loaded dynamically by the application -->
    </ResourceDictionary.MergedDictionaries>

    <!-- Button Style (Simplified for startup compatibility) -->
    <Style x:Key="ThemeButton" TargetType="Button">
        <Setter Property="Background" Value="#0078D4"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#0078D4"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#106EBE"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#005A9E"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#CCCCCC"/>
                            <Setter Property="Foreground" Value="#666666"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DashboardCard Border Style (Simplified) -->
    <Style x:Key="DashboardCard" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#E1E1E1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="Padding" Value="15"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#CCCCCC" BlurRadius="5" ShadowDepth="2"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CardTitle TextBlock Style (Simplified) -->
    <Style x:Key="CardTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="TextAlignment" Value="Left"/>
    </Style>

    <!-- CardValue TextBlock Style (Simplified) -->
    <Style x:Key="CardValue" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#0078D4"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="TextAlignment" Value="Left"/>
    </Style>

    <!-- StatusTextSuccess TextBlock Style -->
    <Style x:Key="StatusTextSuccess" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#107C10"/>
        <Setter Property="FontStyle" Value="Italic"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <!-- StatusTextInfo (Similar) -->
    <Style x:Key="StatusTextInfo" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#0078D4"/>
        <Setter Property="FontStyle" Value="Italic"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,5,0,0"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <!-- BusyText -->
    <Style x:Key="BusyText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#FF6B35"/>
        <Setter Property="FontStyle" Value="Italic"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <!-- StatusBar Style (Expanded with ItemsPanel) -->
    <Style x:Key="ThemeStatusBar" TargetType="StatusBar">
        <Setter Property="Background" Value="#F3F3F3"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <DockPanel LastChildFill="True"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- StatusBarItem Style -->
    <Style x:Key="ThemeStatusBarItem" TargetType="StatusBarItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <!-- Standard Theme Brushes (defined with static colors for early loading) -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="#106EBE"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#107C10"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FF8C00"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#D13438"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#0078D4"/>

    <!-- Background and Foreground Brushes -->
    <SolidColorBrush x:Key="ContentBackground" Color="White"/>
    <SolidColorBrush x:Key="ContentForeground" Color="#333333"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="SelectionBackground" Color="#E6F3FF"/>
    <SolidColorBrush x:Key="SelectionForeground" Color="#333333"/>

