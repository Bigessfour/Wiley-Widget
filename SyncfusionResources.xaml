    <Style x:Key="ThemeRibbonButton" TargetType="syncfusion:RibbonButton">
        <Setter Property="Background" Value="#0078D4"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#0078D4"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>

    <!-- Tab Control Styles -->
    <Style x:Key="ThemeTabControl" TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- SfDataGrid Style - Testing basic properties -->
    <Style x:Key="ThemeSfDataGrid" TargetType="syncfusion:SfDataGrid">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <!-- Advanced row properties not available as direct properties on SfDataGrid -->
        <!-- RowBackground and AlternatingRowBackground properties not supported -->
        <!-- These would need to be implemented via RowStyle or custom templates -->
    </Style>

    <!-- SfChart Style - Testing basic properties -->
    <Style x:Key="ThemeSfChart" TargetType="syncfusion:SfChart">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#333333"/>
