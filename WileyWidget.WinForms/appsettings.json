{
  "_comment": "Production environment configuration for WileyWidget WinForms Application",
  "_security_warning": "This file should be deployed securely. Never commit actual secrets to source control.",

  "DB": {
    "AutoMigrate": false,
    "_comment": "PRODUCTION: Automatic migrations are DISABLED. Use controlled migration scripts via CI/CD pipeline."
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "WileyWidget": "Information",
        "WileyWidget.Security": "Debug",
        "WileyWidget.Services.QuickBooksService": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} - {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "logs/wiley-widget-.log",
                "rollingInterval": "Day",
                "retainedFileCountLimit": 30,
                "fileSizeLimitBytes": 104857600,
                "rollOnFileSizeLimit": true,
                "shared": true,
                "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} - {Message:lj}{NewLine}{Exception}"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "logs/errors-.log",
                "rollingInterval": "Day",
                "retainedFileCountLimit": 60,
                "restrictedToMinimumLevel": "Error",
                "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} - {Message:lj}{NewLine}{Exception}"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "logs/diagnostics-.log",
                "rollingInterval": "Day",
                "retainedFileCountLimit": 7,
                "restrictedToMinimumLevel": "Debug",
                "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {MachineName} PID:{ProcessId} TID:{ThreadId} {SourceContext} - {Message:lj}{NewLine}{Exception}"
              }
            }
          ]
        }
      }
    ]
  },

  "Database": {
    "EnableSensitiveDataLogging": false,
    "EnableDetailedErrors": false,
    "CommandTimeoutSeconds": 45,
    "MaxRetryCount": 5,
    "MaxRetryDelaySeconds": 30,
    "AutoMigrate": false,
    "BackupOnStartup": true,
    "BackupDirectory": "C:\\ProgramData\\WileyWidget\\Backups",
    "BackupCommandTimeoutSeconds": 1800,
    "BackupRetentionDays": 90,
    "_comment": "PRODUCTION: Backups enabled with extended retention. Ensure BackupDirectory has sufficient permissions and disk space."
  },

  "Security": {
    "CriticalSecretsRequired": [
      "QBO-CLIENT-ID",
      "QBO-CLIENT-SECRET",
      "QBO-REALM-ID",
      "SYNCFUSION_LICENSE_KEY",
      "BOLDREPORTS_LICENSE_KEY",
      "APPLICATIONINSIGHTS_CONNECTION_STRING"
    ]
  },

  "HealthChecks": {
    "DefaultTimeout": "00:01:00",
    "DatabaseTimeout": "00:00:45",
    "ExternalServiceTimeout": "00:00:30",
    "MaxRetries": 5,
    "RetryDelay": "00:00:03",
    "CircuitBreakerThreshold": 10,
    "CircuitBreakerTimeout": "00:10:00",
    "ContinueOnFailure": true
  },

  "SigNoz": {
    "Endpoint": "${SIGNOZ_ENDPOINT}",
    "Environment": "production",
    "ServiceName": "wiley-widget",
    "ServiceVersion": "1.0.0",
    "EnableTracing": true,
    "EnableMetrics": true,
    "EnableLogging": true,
    "SampleRatio": 0.1,
    "Headers": "${SIGNOZ_HEADERS}",
    "_comment": "Production SigNoz configuration. Set SIGNOZ_ENDPOINT and SIGNOZ_HEADERS environment variables"
  },

  "ApplicationInsights": {
    "EnableAdaptiveSampling": true,
    "EnablePerformanceCounterCollectionModule": true,
    "EnableDependencyTrackingTelemetryModule": true,
    "EnableAzureInstanceMetadataTelemetryModule": true,
    "EnableAppServicesHeartbeatTelemetryModule": true,
    "EnableEventCounterCollectionModule": true,
    "EnableSqlCommandTextInstrumentation": false,
    "EnableHttpTriggerTelemetry": true,
    "SamplingPercentage": 100
  },

  "ConnectionStrings": {
    "_comment": "PRODUCTION: Use environment variables to override these values. Never commit actual connection strings. DEVELOPMENT: Uses local SQL Server Express fallback if environment variable is not set.",
    "Default": "Server=.\\SQLEXPRESS;Database=WileyWidgetDev;Trusted_Connection=True;TrustServerCertificate=True;",
    "DefaultConnection": "Server=.\\SQLEXPRESS;Database=WileyWidgetDev;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "Syncfusion": {
    "LicenseKey": "${SYNCFUSION_LICENSE_KEY}"
  }
}
