<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <ReportParameters>
    <ReportParameter Name="ReportTitle">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value>Category Breakdown</Value>
        </Values>
      </DefaultValue>
    </ReportParameter>
  </ReportParameters>
  <DataSources>
    <DataSource Name="CategoryData">
      <ConnectionProperties>
        <DataProvider>System.Data.DataSet</DataProvider>
      </ConnectionProperties>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="CategoryDataSet">
      <Query Language="text">
        <DataSetReference DataSet="CategoryData" />
      </Query>
      <Fields>
        <Field Name="Category">
          <DataType>String</DataType>
          <rd:TypeHint>String</rd:TypeHint>
        </Field>
        <Field Name="Amount">
          <DataType>Decimal</DataType>
          <rd:TypeHint>Decimal</rd:TypeHint>
        </Field>
        <Field Name="Percentage">
          <DataType>Decimal</DataType>
          <rd:TypeHint>Decimal</rd:TypeHint>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <Body>
    <ReportItems>
      <Rectangle Name="rectangle1">
        <ReportItems>
          <Textbox Name="ReportTitle">
            <CanGrow>true</CanGrow>
            <CanShrink>false</CanShrink>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>=Parameters!ReportTitle.Value</Value>
                    <Style>
                      <FontFamily>Segoe UI</FontFamily>
                      <FontSize>28pt</FontSize>
                      <FontWeight>Bold</FontWeight>
                      <Color>rgb(33, 37, 41)</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
              </Paragraph>
            </Paragraphs>
            <Left>0.25in</Left>
            <Top>0.25in</Top>
            <Width>6in</Width>
            <Height>0.5in</Height>
          </Textbox>
          <Chart Name="CategoryChart">
            <ChartCategoryHierarchy>
              <ChartMemberCollection>
                <ChartMember>
                  <Group Name="CategoryGroup">
                    <GroupExpressions>
                      <GroupExpression>=Fields!Category.Value</GroupExpression>
                    </GroupExpressions>
                  </Group>
                </ChartMember>
              </ChartMemberCollection>
            </ChartCategoryHierarchy>
            <ChartSeriesHierarchy>
              <ChartMemberCollection>
                <ChartMember>
                  <Group Name="SeriesGroup">
                    <GroupExpressions>
                      <GroupExpression>=Fields!Category.Value</GroupExpression>
                    </GroupExpressions>
                  </Group>
                </ChartMember>
              </ChartMemberCollection>
            </ChartSeriesHierarchy>
            <ChartData>
              <ChartSeriesCollection>
                <ChartSeries Name="Amount">
                  <ChartDataPoints>
                    <ChartDataPoint>
                      <ChartDataPointValues>
                        <Y>=Sum(Fields!Amount.Value)</Y>
                      </ChartDataPointValues>
                      <ChartItemInLegend>None</ChartItemInLegend>
                    </ChartDataPoint>
                  </ChartDataPoints>
                  <Name>Amount</Name>
                </ChartSeries>
              </ChartSeriesCollection>
            </ChartData>
            <ChartAreas>
              <ChartArea Name="Default">
                <ChartCategoryAxes>
                  <ChartAxis Name="Primary">
                    <Style />
                    <ChartAxisTitle>
                      <Caption>Category</Caption>
                      <Style />
                    </ChartAxisTitle>
                    <ChartMajorGridLines>
                      <Enabled>False</Enabled>
                      <Style />
                    </ChartMajorGridLines>
                    <ChartMinorGridLines>
                      <Style />
                    </ChartMinorGridLines>
                  </ChartAxis>
                </ChartCategoryAxes>
                <ChartValueAxes>
                  <ChartAxis Name="Primary">
                    <Style />
                    <ChartAxisTitle>
                      <Caption>Amount</Caption>
                      <Style />
                    </ChartAxisTitle>
                    <ChartMajorGridLines>
                      <Style />
                    </ChartMajorGridLines>
                    <ChartMinorGridLines>
                      <Style />
                    </ChartMinorGridLines>
                  </ChartAxis>
                </ChartValueAxes>
                <Style />
              </ChartArea>
            </ChartAreas>
            <ChartLegends>
              <ChartLegend Name="Default">
                <Style />
              </ChartLegend>
            </ChartLegends>
            <ChartBorderSkin>
              <ChartBorderSkinType>Emboss</ChartBorderSkinType>
              <Style />
            </ChartBorderSkin>
            <ChartPalette>Standard</ChartPalette>
            <ChartEmptyPoints>
              <Style />
            </ChartEmptyPoints>
            <ChartItemsDefaultStyle />
            <ChartSeriessDefaultStyle />
            <ChartCategoryDatasetsDefaultStyle />
            <ChartSeriesDatasetsDefaultStyle />
            <DataSetName>CategoryDataSet</DataSetName>
            <Top>0.8in</Top>
            <Left>0.25in</Left>
            <Height>3in</Height>
            <Width>6in</Width>
            <Style />
          </Chart>
          <Table Name="CategoryTable">
            <DataSetName>CategoryDataSet</DataSetName>
            <Visibility>
              <Hidden>false</Hidden>
            </Visibility>
            <TableColumns>
              <TableColumn>
                <Width>2.5in</Width>
              </TableColumn>
              <TableColumn>
                <Width>1.75in</Width>
              </TableColumn>
              <TableColumn>
                <Width>1.75in</Width>
              </TableColumn>
            </TableColumns>
            <TableRows>
              <TableRow>
                <Height>0.3in</Height>
                <TableCells>
                  <TableCell>
                    <ReportItems>
                      <Textbox Name="CatHeaderCell">
                        <Paragraphs>
                          <Paragraph>
                            <TextRuns>
                              <TextRun>
                                <Value>Category</Value>
                                <Style>
                                  <FontFamily>Segoe UI</FontFamily>
                                  <FontSize>11pt</FontSize>
                                  <FontWeight>Bold</FontWeight>
                                  <Color>white</Color>
                                </Style>
                              </TextRun>
                            </TextRuns>
                            <TextAlign>Left</TextAlign>
                          </Paragraph>
                        </Paragraphs>
                        <Style>
                          <BackgroundColor>rgb(33, 37, 41)</BackgroundColor>
                          <PaddingLeft>0.1in</PaddingLeft>
                          <PaddingRight>0.1in</PaddingRight>
                        </Style>
                      </Textbox>
                    </ReportItems>
                  </TableCell>
                  <TableCell>
                    <ReportItems>
                      <Textbox Name="AmountHeaderCell">
                        <Paragraphs>
                          <Paragraph>
                            <TextRuns>
                              <TextRun>
                                <Value>Amount</Value>
                                <Style>
                                  <FontFamily>Segoe UI</FontFamily>
                                  <FontSize>11pt</FontSize>
                                  <FontWeight>Bold</FontWeight>
                                  <Color>white</Color>
                                </Style>
                              </TextRun>
                            </TextRuns>
                            <TextAlign>Right</TextAlign>
                          </Paragraph>
                        </Paragraphs>
                        <Style>
                          <BackgroundColor>rgb(33, 37, 41)</BackgroundColor>
                          <PaddingLeft>0.1in</PaddingLeft>
                          <PaddingRight>0.1in</PaddingRight>
                        </Style>
                      </Textbox>
                    </ReportItems>
                  </TableCell>
                  <TableCell>
                    <ReportItems>
                      <Textbox Name="PctHeaderCell">
                        <Paragraphs>
                          <Paragraph>
                            <TextRuns>
                              <TextRun>
                                <Value>Percent</Value>
                                <Style>
                                  <FontFamily>Segoe UI</FontFamily>
                                  <FontSize>11pt</FontSize>
                                  <FontWeight>Bold</FontWeight>
                                  <Color>white</Color>
                                </Style>
                              </TextRun>
                            </TextRuns>
                            <TextAlign>Right</TextAlign>
                          </Paragraph>
                        </Paragraphs>
                        <Style>
                          <BackgroundColor>rgb(33, 37, 41)</BackgroundColor>
                          <PaddingLeft>0.1in</PaddingLeft>
                          <PaddingRight>0.1in</PaddingRight>
                        </Style>
                      </Textbox>
                    </ReportItems>
                  </TableCell>
                </TableCells>
              </TableRow>
              <TableRow>
                <Height>0.25in</Height>
                <TableCells>
                  <TableCell>
                    <ReportItems>
                      <Textbox Name="CatCell">
                        <Paragraphs>
                          <Paragraph>
                            <TextRuns>
                              <TextRun>
                                <Value>=Fields!Category.Value</Value>
                                <Style>
                                  <FontFamily>Segoe UI</FontFamily>
                                  <FontSize>10pt</FontSize>
                                </Style>
                              </TextRun>
                            </TextRuns>
                          </Paragraph>
                        </Paragraphs>
                        <Style>
                          <BorderStyle>
                            <Default>Solid</Default>
                          </BorderStyle>
                          <BorderWidth>
                            <Default>0.5pt</Default>
                          </BorderWidth>
                          <BorderColor>
                            <Default>rgb(220, 220, 220)</Default>
                          </BorderColor>
                          <PaddingLeft>0.1in</PaddingLeft>
                          <PaddingRight>0.1in</PaddingRight>
                        </Style>
                      </Textbox>
                    </ReportItems>
                  </TableCell>
                  <TableCell>
                    <ReportItems>
                      <Textbox Name="AmountCell">
                        <Paragraphs>
                          <Paragraph>
                            <TextRuns>
                              <TextRun>
                                <Value>=Format(Fields!Amount.Value, "C")</Value>
                                <Style>
                                  <FontFamily>Segoe UI</FontFamily>
                                  <FontSize>10pt</FontSize>
                                </Style>
                              </TextRun>
                            </TextRuns>
                            <TextAlign>Right</TextAlign>
                          </Paragraph>
                        </Paragraphs>
                        <Style>
                          <BorderStyle>
                            <Default>Solid</Default>
                          </BorderStyle>
                          <BorderWidth>
                            <Default>0.5pt</Default>
                          </BorderWidth>
                          <BorderColor>
                            <Default>rgb(220, 220, 220)</Default>
                          </BorderColor>
                          <PaddingLeft>0.1in</PaddingLeft>
                          <PaddingRight>0.1in</PaddingRight>
                        </Style>
                      </Textbox>
                    </ReportItems>
                  </TableCell>
                  <TableCell>
                    <ReportItems>
                      <Textbox Name="PctCell">
                        <Paragraphs>
                          <Paragraph>
                            <TextRuns>
                              <TextRun>
                                <Value>=Format(Fields!Percentage.Value / 100, "P1")</Value>
                                <Style>
                                  <FontFamily>Segoe UI</FontFamily>
                                  <FontSize>10pt</FontSize>
                                </Style>
                              </TextRun>
                            </TextRuns>
                            <TextAlign>Right</TextAlign>
                          </Paragraph>
                        </Paragraphs>
                        <Style>
                          <BorderStyle>
                            <Default>Solid</Default>
                          </BorderStyle>
                          <BorderWidth>
                            <Default>0.5pt</Default>
                          </BorderWidth>
                          <BorderColor>
                            <Default>rgb(220, 220, 220)</Default>
                          </BorderColor>
                          <PaddingLeft>0.1in</PaddingLeft>
                          <PaddingRight>0.1in</PaddingRight>
                        </Style>
                      </Textbox>
                    </ReportItems>
                  </TableCell>
                </TableCells>
              </TableRow>
            </TableRows>
            <Left>0.25in</Left>
            <Top>4in</Top>
            <Width>6in</Width>
            <Height>1in</Height>
          </Table>
          <Textbox Name="FooterText">
            <CanGrow>true</CanGrow>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>="Generated: " &amp; Now()</Value>
                    <Style>
                      <FontFamily>Segoe UI</FontFamily>
                      <FontSize>9pt</FontSize>
                      <Color>rgb(150, 150, 150)</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
              </Paragraph>
            </Paragraphs>
            <Left>0.25in</Left>
            <Top>5.2in</Top>
            <Width>6in</Width>
            <Height>0.25in</Height>
          </Textbox>
        </ReportItems>
        <Height>5.5in</Height>
        <Width>6.5in</Width>
      </Rectangle>
    </ReportItems>
    <Height>5.5in</Height>
  </Body>
  <Width>7in</Width>
  <Page>
    <LeftMargin>0.5in</LeftMargin>
    <RightMargin>0.5in</RightMargin>
    <TopMargin>0.5in</TopMargin>
    <BottomMargin>0.5in</BottomMargin>
    <ColumnSpacing>0.13in</ColumnSpacing>
    <Style />
