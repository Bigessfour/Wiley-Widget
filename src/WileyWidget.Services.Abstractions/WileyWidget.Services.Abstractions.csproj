<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Align TFM with solution-wide Windows target to avoid project compatibility (NU1201) -->
    <TargetFrameworks>net9.0;net9.0-windows</TargetFrameworks>
    <GenerateWinMD Condition="$(TargetFramework.Contains('windows'))">true</GenerateWinMD>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <NoWarn>NU1902;NU1903</NoWarn>
    <IsPackable>false</IsPackable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <!-- Package versions managed centrally in Directory.Packages.props -->
    <PackageReference Include="Microsoft.Extensions.Primitives" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="IppOAuth2PlatformSdk" />
    <PackageReference Include="IppDotNetSdkForQuickBooksApiV3" />
  </ItemGroup>

  <ItemGroup>
    <!-- Abstractions need model types (Enterprise, BudgetData, ServiceChargeRecommendation, etc.) -->
    <ProjectReference Include="..\WileyWidget.Models\WileyWidget.Models.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Serilog.Sinks.AzureDocumentDB" ExcludeAssets="All" />
    <PackageReference Include="Microsoft.Azure.DocumentDB.Core" ExcludeAssets="All" />
  </ItemGroup>

</Project>