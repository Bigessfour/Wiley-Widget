@namespace WileyWidget.WinForms.BlazorComponents
@page "/"
@using System
@using System.Collections.Generic
@using System.IO
@using System.Linq
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Syncfusion.Blazor.InteractiveChat
@using WileyWidget.Models
@using WileyWidget.Services.Abstractions
@using WileyWidget.WinForms.Services.AI
@using WileyWidget.WinForms.Services
@using SfChatMessage = Syncfusion.Blazor.InteractiveChat.ChatMessage
@using SfUserModel = Syncfusion.Blazor.InteractiveChat.UserModel
@implements IDisposable
@inject IChatBridgeService ChatBridge
@inject IThemeService ThemeService
@inject ILogger<JARVISAssist> Logger
@inject IJSRuntime JS

<div class="jarvis-chat-shell">
    <SfChatUI @ref="_chatUi"
              ID="jarvisChat"
              User="_currentUser"
              Messages="_messages"
              TypingUsers="_typingUsers"
              Height="100%"
              Width="100%"
              ShowHeader="false"
              ShowTimeBreak="true"
              ShowTimestamp="true"
              AutoScrollToBottom="true"
              MessageSend="HandleMessageSend"
              UserTyping="HandleUserTyping">
        <EmptyChatTemplate>
            <div class="jarvis-empty">
                <h3>Welcome to JARVIS</h3>
                <p>Ask questions about budgets, payments, audits, and municipal operations.</p>
            </div>
        </EmptyChatTemplate>
        <FooterTemplate>
            <div class="jarvis-footer">
                @if (_pendingAttachments.Count > 0)
                {
                    <div class="jarvis-attachment-strip">
                        @foreach (var attachment in _pendingAttachments)
                        {
                            <div class="jarvis-attachment-chip" title="@attachment.FileName">
                                <span class="jarvis-attachment-name">@attachment.FileName</span>
                                <span class="jarvis-attachment-meta">@attachment.GetDisplaySize()</span>
                                @if (attachment.IsTruncated)
                                {
                                    <span class="jarvis-attachment-meta">truncated</span>
                                }
                                <button type="button"
                                        class="jarvis-attachment-remove"
                                        aria-label="Remove @attachment.FileName"
                                        @onclick="() => RemoveAttachment(attachment.FileName)">
                                    x
                                </button>
                            </div>
                        }
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(_attachmentError))
                {
                    <div class="jarvis-attachment-error">@_attachmentError</div>
                }

                <div class="jarvis-compose-row">
                    <label class="jarvis-attach-button" title="Attach a file for JARVIS to evaluate">
                        <span class="jarvis-attach-icon" aria-hidden="true">&#128206;</span>
                        <span>Attach</span>
                        <InputFile class="jarvis-file-input"
                                   OnChange="HandleAttachmentSelectedAsync"
                                   multiple
                                   accept="@AcceptedAttachmentTypes" />
                    </label>

                    <textarea @ref="_composerInput"
                              class="jarvis-compose-input"
                              rows="3"
                              @bind="_draftText"
                              @bind:event="oninput"
                              @onkeydown="HandleComposerKeyDownAsync"
                              placeholder="Ask JARVIS a question or attach a file for evaluation..."></textarea>

                    <button type="button"
                            class="jarvis-send-button"
                            @onclick="SendDraftAsync"
                            disabled="@IsSendDisabled">
                        Send
                    </button>
                </div>
            </div>
        </FooterTemplate>
    </SfChatUI>
</div>

@code {
    private SfChatUI? _chatUi;
    private ElementReference _composerInput;
    private readonly List<SfChatMessage> _messages = new();
    private readonly List<SfUserModel> _typingUsers = new();
    private readonly SfUserModel _currentUser = new() { ID = "jarvis-current-user", User = "You" };
    private readonly SfUserModel _assistantUser = new() { ID = "jarvis-assistant-user", User = "JARVIS" };
    private static readonly string[] SupportedAttachmentExtensions =
    {
        ".txt",
        ".md",
        ".log",
        ".json",
        ".xml",
        ".csv",
        ".yml",
        ".yaml",
        ".config",
        ".cs",
        ".csproj",
        ".razor",
        ".sql",
        ".ps1"
    };
    private const int MaxAttachmentCount = 3;
    private const long MaxAttachmentBytes = 256 * 1024;
    private const int MaxAttachmentCharacters = 24_000;
    private static readonly string AcceptedAttachmentTypes = string.Join(",", SupportedAttachmentExtensions);
    private readonly List<ChatPromptAttachment> _pendingAttachments = new();
    private string? _streamingMessageId;
    private string _draftText = string.Empty;
    private string? _attachmentError;
    private bool _isDisposed;
    private bool IsSendDisabled => string.IsNullOrWhiteSpace(_draftText) && _pendingAttachments.Count == 0;

    protected override void OnInitialized()
    {
        Logger?.LogInformation("[JARVIS-BLAZOR] SfChatUI component initializing");

        ChatBridge.OnMessageReceived += HandleMessageReceived;
        ChatBridge.ResponseChunkReceived += HandleResponseChunk;
        ChatBridge.ResponseCompleted += HandleResponseCompleted;
        ChatBridge.ExternalPromptRequested += HandleExternalPromptRequested;
        ThemeService.ThemeChanged += HandleThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ApplyThemeAsync(ThemeService.CurrentTheme, ThemeService.IsDark);

            await Task.Delay(150);

            try
            {
                if (_chatUi != null)
                {
                    if (!await IsSyncfusionInteropReadyAsync())
                    {
                        Logger?.LogDebug("[JARVIS] Syncfusion interop not ready during first render focus attempt");
                    }

                    await FocusComposerAsync();
                    Logger?.LogInformation("[JARVIS] Input focused successfully after safe delay");
                }
            }
            catch (JSException ex)
            {
                Logger?.LogWarning(ex, "[JARVIS] Focus failed due to JS readiness race — non-critical, continuing");
            }
            catch (Exception ex)
            {
                Logger?.LogWarning(ex, "[JARVIS] Focus failed — non-critical, continuing");
            }
        }

        if (_messages.Count > 0 || !string.IsNullOrEmpty(_streamingMessageId))
        {
            await ScrollToBottomAsync();
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task HandleMessageSend(ChatMessageSendEventArgs args)
    {
        args.Cancel = true;

        await SubmitPromptAsync(args.Message?.Text, includePendingAttachments: false);
    }

    private void HandleExternalPromptRequested(object? sender, ChatExternalPromptEventArgs args)
    {
        if (string.IsNullOrWhiteSpace(args.Prompt))
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            AddUserMessage(JarvisAttachmentPromptFormatter.BuildDisplayPrompt(args.Prompt, args.Attachments), allowDuplicate: false);
            SetTypingIndicator(isTyping: true);
            StateHasChanged();
            await ScrollToBottomAsync();
        });
    }

    private void HandleResponseChunk(object? sender, ChatResponseChunkEventArgs args)
    {
        if (string.IsNullOrWhiteSpace(args.Chunk))
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            AppendAssistantChunk(args.Chunk);
            SetTypingIndicator(isTyping: true);
            StateHasChanged();
            await ScrollToBottomAsync();
        });
    }

    private void HandleResponseCompleted(object? sender, EventArgs args)
    {
        _ = InvokeAsync(async () =>
        {
            _streamingMessageId = null;
            SetTypingIndicator(isTyping: false);
            StateHasChanged();
            await ScrollToBottomAsync();
        });
    }

    private void HandleMessageReceived(object? sender, WileyWidget.Models.ChatMessage message)
    {
        if (string.IsNullOrWhiteSpace(message.Content))
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            if (message.IsUser)
            {
                AddUserMessage(message.Content, allowDuplicate: false, timestamp: message.Timestamp.ToLocalTime());
            }
            else
            {
                if (!TryResolveStreamingDuplicate(message.Content))
                {
                    AddAssistantMessage(message.Content, message.Timestamp.ToLocalTime());
                }

                _streamingMessageId = null;
                SetTypingIndicator(isTyping: false);
            }

            StateHasChanged();
            await ScrollToBottomAsync();
        });
    }

    private void HandleThemeChanged(object? sender, string themeName)
    {
        _ = InvokeAsync(() => ApplyThemeAsync(themeName, ThemeService.IsDark));
    }

    private void HandleUserTyping(ChatUserTypingEventArgs args)
    {
        Logger?.LogDebug("[JARVIS-BLAZOR] UserTyping event IsTyping={IsTyping}", args.IsTyping);
    }

    private async Task HandleComposerKeyDownAsync(KeyboardEventArgs args)
    {
        if (string.Equals(args.Key, "Enter", StringComparison.Ordinal)
            && !args.ShiftKey
            && !args.CtrlKey
            && !args.AltKey
            && !args.MetaKey)
        {
            await SendDraftAsync();
        }
    }

    private async Task SendDraftAsync()
    {
        await SubmitPromptAsync(_draftText, includePendingAttachments: true);
    }

    private async Task SubmitPromptAsync(string? promptText, bool includePendingAttachments)
    {
        var attachments = includePendingAttachments
            ? _pendingAttachments.ToArray()
            : Array.Empty<ChatPromptAttachment>();

        if (attachments.Length == 0 && string.IsNullOrWhiteSpace(promptText))
        {
            return;
        }

        var normalizedPrompt = JarvisAttachmentPromptFormatter.NormalizePrompt(promptText);

        var displayPrompt = JarvisAttachmentPromptFormatter.BuildDisplayPrompt(normalizedPrompt, attachments);

        AddUserMessage(displayPrompt, allowDuplicate: false);
        SetTypingIndicator(isTyping: true);
        _attachmentError = null;

        if (includePendingAttachments)
        {
            _draftText = string.Empty;
            _pendingAttachments.Clear();
        }

        StateHasChanged();
        await ScrollToBottomAsync();

        try
        {
            if (attachments.Length > 0)
            {
                await ChatBridge.RequestExternalPromptAsync(normalizedPrompt, attachments);
            }
            else
            {
                await ChatBridge.RequestExternalPromptAsync(normalizedPrompt);
            }

            await FocusComposerAsync();
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "[JARVIS-BLAZOR] Failed to submit prompt via bridge");
            SetTypingIndicator(isTyping: false);

            if (includePendingAttachments)
            {
                _draftText = promptText?.Trim() ?? string.Empty;
                _pendingAttachments.AddRange(attachments);
            }

            AddAssistantMessage($"Error: {ex.Message}");
            await ScrollToBottomAsync();
            StateHasChanged();
        }
    }

    private async Task HandleAttachmentSelectedAsync(InputFileChangeEventArgs args)
    {
        var feedback = new List<string>();
        var selectedFiles = args.GetMultipleFiles(args.FileCount);

        foreach (var file in selectedFiles)
        {
            var existingIndex = _pendingAttachments.FindIndex(existing =>
                string.Equals(existing.FileName, file.Name, StringComparison.OrdinalIgnoreCase));

            if (existingIndex < 0 && _pendingAttachments.Count >= MaxAttachmentCount)
            {
                feedback.Add($"Only {MaxAttachmentCount} attachments are allowed per message.");
                break;
            }

            var (attachment, error) = await TryCreateAttachmentAsync(file);
            if (attachment == null)
            {
                if (!string.IsNullOrWhiteSpace(error))
                {
                    feedback.Add(error);
                }

                continue;
            }

            if (existingIndex >= 0)
            {
                _pendingAttachments[existingIndex] = attachment;
            }
            else
            {
                _pendingAttachments.Add(attachment);
            }
        }

        _attachmentError = feedback.Count == 0 ? null : string.Join(" ", feedback.Distinct(StringComparer.Ordinal));
        StateHasChanged();
        await FocusComposerAsync();
    }

    private async Task<(ChatPromptAttachment? Attachment, string? Error)> TryCreateAttachmentAsync(IBrowserFile file)
    {
        var extension = Path.GetExtension(file.Name);
        if (!SupportedAttachmentExtensions.Contains(extension, StringComparer.OrdinalIgnoreCase))
        {
            return (null, $"{file.Name}: unsupported file type. Attach text-based files such as .txt, .log, .json, .xml, .cs, or .sql.");
        }

        if (file.Size <= 0)
        {
            return (null, $"{file.Name}: file is empty.");
        }

        if (file.Size > MaxAttachmentBytes)
        {
            return (null, $"{file.Name}: file is larger than {MaxAttachmentBytes / 1024} KB.");
        }

        try
        {
            await using var stream = file.OpenReadStream(MaxAttachmentBytes);
            using var reader = new StreamReader(stream);
            var content = await reader.ReadToEndAsync();
            var isTruncated = false;
            if (content.Length > MaxAttachmentCharacters)
            {
                isTruncated = true;
                content = string.Concat(
                    content[..MaxAttachmentCharacters],
                    Environment.NewLine,
                    Environment.NewLine,
                    $"[Attachment truncated to the first {MaxAttachmentCharacters:N0} characters for chat submission.]");
            }

            return (new ChatPromptAttachment
            {
                FileName = file.Name,
                ContentType = string.IsNullOrWhiteSpace(file.ContentType) ? "text/plain" : file.ContentType,
                SizeBytes = file.Size,
                Content = content,
                IsTruncated = isTruncated
            }, null);
        }
        catch (Exception ex)
        {
            Logger?.LogWarning(ex, "[JARVIS-BLAZOR] Failed to read attachment {FileName}", file.Name);
            return (null, $"{file.Name}: could not be read for evaluation.");
        }
    }

    private void RemoveAttachment(string fileName)
    {
        _pendingAttachments.RemoveAll(attachment =>
            string.Equals(attachment.FileName, fileName, StringComparison.OrdinalIgnoreCase));

        if (_pendingAttachments.Count == 0)
        {
            _attachmentError = null;
        }
    }

    private void AppendAssistantChunk(string chunk)
    {
        if (string.IsNullOrEmpty(_streamingMessageId))
        {
            var newMessage = CreateMessage(_assistantUser, chunk, DateTime.Now);
            _messages.Add(newMessage);
            _streamingMessageId = newMessage.ID;
            return;
        }

        var currentMessage = _messages.FirstOrDefault(message =>
            string.Equals(message.ID, _streamingMessageId, StringComparison.Ordinal));

        if (currentMessage == null)
        {
            var fallbackMessage = CreateMessage(_assistantUser, chunk, DateTime.Now);
            _messages.Add(fallbackMessage);
            _streamingMessageId = fallbackMessage.ID;
            return;
        }

        currentMessage.Text = string.Concat(currentMessage.Text ?? string.Empty, chunk);
    }

    private bool TryResolveStreamingDuplicate(string finalMessage)
    {
        if (string.IsNullOrEmpty(_streamingMessageId))
        {
            return false;
        }

        var currentMessage = _messages.FirstOrDefault(message =>
            string.Equals(message.ID, _streamingMessageId, StringComparison.Ordinal));

        if (currentMessage == null)
        {
            return false;
        }

        return string.Equals(
            (currentMessage.Text ?? string.Empty).Trim(),
            finalMessage.Trim(),
            StringComparison.Ordinal);
    }

    private void AddUserMessage(string messageText, bool allowDuplicate, DateTime? timestamp = null)
    {
        if (string.IsNullOrWhiteSpace(messageText))
        {
            return;
        }

        if (!allowDuplicate)
        {
            var lastMessage = _messages.LastOrDefault();
            if (lastMessage?.Author?.ID == _currentUser.ID &&
                string.Equals((lastMessage.Text ?? string.Empty).Trim(), messageText.Trim(), StringComparison.Ordinal))
            {
                return;
            }
        }

        _messages.Add(CreateMessage(_currentUser, messageText.Trim(), timestamp ?? DateTime.Now));
    }

    private void AddAssistantMessage(string messageText, DateTime? timestamp = null)
    {
        if (string.IsNullOrWhiteSpace(messageText))
        {
            return;
        }

        _messages.Add(CreateMessage(_assistantUser, messageText.Trim(), timestamp ?? DateTime.Now));
    }

    private static SfChatMessage CreateMessage(SfUserModel author, string text, DateTime timestamp)
    {
        return new SfChatMessage
        {
            // Syncfusion chat toolbar lookup uses querySelector("#<messageId>").
            // IDs starting with digits are not valid CSS selectors unless escaped.
            ID = CreateCssSafeMessageId(),
            Author = author,
            Text = text,
            Timestamp = timestamp
        };
    }

    private static string CreateCssSafeMessageId()
    {
        return $"msg-{Guid.NewGuid():N}";
    }

    private void SetTypingIndicator(bool isTyping)
    {
        _typingUsers.Clear();
        if (isTyping)
        {
            _typingUsers.Add(_assistantUser);
        }
    }

    private async Task ScrollToBottomAsync()
    {
        if (_chatUi == null)
        {
            return;
        }

        try
        {
            await _chatUi.ScrollToBottomAsync();
        }
        catch (JSException ex)
        {
            Logger?.LogDebug(ex, "[JARVIS-BLAZOR] ScrollToBottomAsync skipped due to transient JS interop readiness state");
        }
        catch (Exception ex)
        {
            Logger?.LogWarning(ex, "[JARVIS-BLAZOR] ScrollToBottomAsync failed");
        }
    }

    private async Task<bool> IsSyncfusionInteropReadyAsync()
    {
        try
        {
            return await JS.InvokeAsync<bool>("eval", "typeof window !== 'undefined' && !!window.ejs");
        }
        catch (Exception ex)
        {
            Logger?.LogDebug(ex, "[JARVIS-BLAZOR] Unable to probe Syncfusion JS readiness");
            return false;
        }
    }

    private async Task ApplyThemeAsync(string themeName, bool isDark)
    {
        try
        {
            await JS.InvokeVoidAsync("jarvisTheme.applyTheme", themeName, isDark);
            Logger?.LogDebug("[JARVIS-BLAZOR] Applied theme bridge: {Theme} (IsDark={IsDark})", themeName, isDark);
        }
        catch (Exception ex)
        {
            Logger?.LogWarning(ex, "[JARVIS-BLAZOR] Failed to apply theme bridge");
        }
    }

    private async Task FocusComposerAsync()
    {
        try
        {
            await _composerInput.FocusAsync();
        }
        catch (Exception ex)
        {
            Logger?.LogDebug(ex, "[JARVIS-BLAZOR] Composer focus skipped due to transient render state");
        }
    }

    public void Dispose()
    {
        if (_isDisposed)
        {
            return;
        }

        _isDisposed = true;
        ChatBridge.OnMessageReceived -= HandleMessageReceived;
        ChatBridge.ResponseChunkReceived -= HandleResponseChunk;
        ChatBridge.ResponseCompleted -= HandleResponseCompleted;
        ChatBridge.ExternalPromptRequested -= HandleExternalPromptRequested;
        ThemeService.ThemeChanged -= HandleThemeChanged;
    }
}

<style>
    .jarvis-chat-shell {
        width: 100%;
        height: 100%;
        background: #17181c;
        color: #f3f6fb;
    }

    .jarvis-empty {
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        gap: 0.5rem;
        background: inherit;
    }

    [data-jarvis-mode="light"] .jarvis-chat-shell {
        background: #f5f7fb;
        color: #17202b;
    }

    .jarvis-footer {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        padding: 0.75rem;
        border-top: 1px solid rgba(128, 128, 128, 0.2);
        background: rgba(255, 255, 255, 0.72);
        backdrop-filter: blur(6px);
    }

    .jarvis-compose-row {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 0.75rem;
        align-items: end;
    }

    .jarvis-attach-button {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.7rem 0.85rem;
        border-radius: 0.75rem;
        border: 1px solid rgba(128, 128, 128, 0.35);
        cursor: pointer;
        font-weight: 600;
        user-select: none;
        white-space: nowrap;
        background: rgba(255, 255, 255, 0.9);
    }

    .jarvis-attach-icon {
        font-size: 1rem;
        line-height: 1;
    }

    .jarvis-file-input {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
    }

    .jarvis-compose-input {
        width: 100%;
        min-height: 3.75rem;
        resize: vertical;
        border-radius: 0.85rem;
        border: 1px solid rgba(128, 128, 128, 0.35);
        padding: 0.75rem 0.9rem;
        font: inherit;
        background: rgba(255, 255, 255, 0.95);
    }

    .jarvis-send-button {
        min-width: 5.5rem;
        padding: 0.75rem 1rem;
        border: none;
        border-radius: 0.85rem;
        font-weight: 700;
        cursor: pointer;
        color: #ffffff;
        background: linear-gradient(135deg, #0b5cab, #178b6b);
    }

    .jarvis-send-button:disabled {
        cursor: default;
        opacity: 0.5;
    }

    .jarvis-attachment-strip {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .jarvis-attachment-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        max-width: 100%;
        padding: 0.35rem 0.55rem;
        border-radius: 999px;
        background: rgba(11, 92, 171, 0.12);
        color: #0b3d70;
        font-size: 0.9rem;
    }

    .jarvis-attachment-name {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 18rem;
    }

    .jarvis-attachment-meta {
        font-size: 0.78rem;
        opacity: 0.72;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .jarvis-attachment-remove {
        border: none;
        background: transparent;
        color: inherit;
        cursor: pointer;
        font-weight: 700;
        padding: 0;
    }

    .jarvis-attachment-error {
        color: #a12a1a;
        font-size: 0.9rem;
    }

    [data-jarvis-mode="dark"] .jarvis-footer {
        background: rgba(23, 24, 28, 0.82);
    }

    [data-jarvis-mode="dark"] .jarvis-attach-button,
    [data-jarvis-mode="dark"] .jarvis-compose-input {
        background: rgba(32, 34, 40, 0.94);
        color: #f3f6fb;
        border-color: rgba(255, 255, 255, 0.16);
    }

    [data-jarvis-mode="dark"] .jarvis-attachment-chip {
        background: rgba(91, 169, 255, 0.18);
        color: #d6e9ff;
    }

    @@media (max-width: 640px) {
        .jarvis-compose-row {
            grid-template-columns: 1fr;
        }

        .jarvis-send-button {
            width: 100%;
        }
    }
</style>
