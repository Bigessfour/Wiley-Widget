{
  "Authentication": {
    "Mode": "DevelopmentBypass",
    "Onboarding": {
      "Enabled": true,
      "RequireTermsConsent": false,
      "RequirePrivacyConsent": false,
      "EnablePhoneForSmsMfa": true,
      "AutoGrantConsentInDevelopmentBypass": true,
      "RequiredProfileFields": ["DisplayName", "Email"]
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Override": {
        "WileyWidget.WinForms.Controls.Panels": "Verbose",
        "WileyWidget.WinForms.Controls.Base": "Verbose"
      }
    }
  }
}
