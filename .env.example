# Environment variables for Wiley Widget application
# Copy this file to .env and fill in your actual values

# QuickBooks Configuration (if needed)
QBO_CLIENT_ID=your-quickbooks-client-id
QBO_CLIENT_SECRET=your-quickbooks-client-secret
QBO_REDIRECT_URI=https://localhost:5001/callback
QBO_ENVIRONMENT=sandbox

# Development Settings
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:5001;http://localhost:5000

# AI Service API Keys
XAI_API_KEY=your-xai-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Syncfusion License Configuration
SYNCFUSION_LICENSE_KEY=your-syncfusion-license-key-here

# MCP Server Configuration
GITHUB_TOKEN=your-github-personal-access-token-here
SYNCFUSION_MCP_API_KEY=your-syncfusion-mcp-api-key-here
# AZURE_SUBSCRIPTION_KEY=your-azure-subscription-key-here  # Removed - no Azure MCP server
